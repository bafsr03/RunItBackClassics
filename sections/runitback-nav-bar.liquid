
{%- liquid
  assign all_links = linklists[section.settings.menu].links
  assign total     = all_links.size
  assign half      = total | divided_by: 2
-%}

<style>
  #shopify-section-{{ section.id }} {
    position: relative !important;
    z-index: 2147483647 !important;
  }
</style>

<nav
  class="rb-navb color-scheme-5"
  id="rb-navb-{{ section.id }}"
  aria-label="{{ shop.name }} navigation"
>
  <div class="rb-navb__inner rb-container">

    {%- comment -%} LEFT MENU — first half of links {%- endcomment -%}
    <ul class="rb-navb__list rb-navb__list--left" role="list">
      {%- for link in all_links -%}
        {%- if forloop.index <= half -%}
          <li class="rb-navb__item{% if link.links.size > 0 %} rb-navb__item--has-drop{% endif %}">
            <a
              href="{{ link.url }}"
              class="rb-navb__link{% if link.current %} rb-navb__link--active{% endif %}"
              {% if link.current %}aria-current="page"{% endif %}
            >
              {{- link.title -}}
              {%- if link.links.size > 0 -%}
                <svg class="rb-navb__caret" viewBox="0 0 10 6" fill="none" width="10" height="6">
                  <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              {%- endif -%}
            </a>
            {%- if link.links.size > 0 -%}
              <ul class="rb-navb__dropdown" role="list">
                {%- for child in link.links -%}
                  <li>
                    <a href="{{ child.url }}" class="rb-navb__dropdown-link{% if child.current %} rb-navb__link--active{% endif %}">
                      {{- child.title -}}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>

    {%- comment -%} CENTER LOGO {%- endcomment -%}
    <a href="{{ routes.root_url }}" class="rb-navb__logo" aria-label="{{ shop.name }} home">
      {%- if settings.logo != blank -%}
        {{- settings.logo
          | image_url: height: 80
          | image_tag:
            alt: shop.name,
            loading: 'eager',
            class: 'rb-navb__logo-img'
        -}}
      {%- else -%}
        <span class="rb-navb__wordmark">{{ shop.name | upcase }}</span>
      {%- endif -%}
    </a>

    {%- comment -%} RIGHT MENU — second half of links {%- endcomment -%}
    <ul class="rb-navb__list rb-navb__list--right" role="list">
      {%- for link in all_links -%}
        {%- if forloop.index > half -%}
          <li class="rb-navb__item{% if link.links.size > 0 %} rb-navb__item--has-drop{% endif %}">
            <a
              href="{{ link.url }}"
              class="rb-navb__link{% if link.current %} rb-navb__link--active{% endif %}{% if link.title == 'Sale' or link.title == 'SALE' or link.title == 'Rebajas' or link.title == 'REBAJAS' %} rb-navb__link--sale{% endif %}"
              {% if link.current %}aria-current="page"{% endif %}
            >
              {{- link.title -}}
              {%- if link.links.size > 0 -%}
                <svg class="rb-navb__caret" viewBox="0 0 10 6" fill="none" width="10" height="6">
                  <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              {%- endif -%}
            </a>
            {%- if link.links.size > 0 -%}
              <ul class="rb-navb__dropdown" role="list">
                {%- for child in link.links -%}
                  <li>
                    <a href="{{ child.url }}" class="rb-navb__dropdown-link{% if child.current %} rb-navb__link--active{% endif %}">
                      {{- child.title -}}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>

  </div>
</nav>

{% stylesheet %}
/* ================================================================
   RB NAV BAR — Rokit-style: items | LOGO badge | items
   Light / white colourway — logo overflows below like Rokit
   ================================================================ */

.rb-navb {
  display: none;
  background: var(--color-background, #0f0f0f);
  /* border-bottom removed as requested */
  border-bottom: none;
  position: relative;
  /* High z-index so the overflowing logo badge sits above
     whatever section comes directly below the nav AND above it */
  z-index: 9999;
  overflow: visible;
}

@media (min-width: 990px) {
  .rb-navb { display: block; }
}

/* ---- inner grid ---- */
.rb-navb__inner {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  height: 60px;
  overflow: visible;
}

/* ---- nav lists ---- */
.rb-navb__list {
  display: flex;
  align-items: center;
  list-style: none;
  margin: 0;
  padding: 0;
  height: 100%;
}

.rb-navb__list--left  { justify-content: flex-end; }
.rb-navb__list--right { justify-content: flex-start; }

/* ---- nav items ---- */
.rb-navb__item {
  position: relative;
  height: 100%;
  display: flex;
  align-items: center;
}

/* ---- nav links ---- */
.rb-navb__link {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 0 20px;
  height: 100%;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.65);
  text-decoration: none;
  white-space: nowrap;
  transition: color 0.2s ease;
  position: relative;
}

/* lime bottom-bar indicator on hover / active */
.rb-navb__link::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20px;
  right: 20px;
  height: 2px;
  background: #c8f135;
  transform: scaleX(0);
  transform-origin: center;
  transition: transform 0.25s ease;
}

.rb-navb__link:hover,
.rb-navb__link--active {
  color: #ffffff;
}

.rb-navb__link:hover::after,
.rb-navb__link--active::after {
  transform: scaleX(1);
}

/* sale */
.rb-navb__link--sale            { color: #ff2d2d !important; }
.rb-navb__link--sale:hover      { color: #cc0000 !important; }
.rb-navb__link--sale::after     { background: #ff2d2d; }

/* ---- caret ---- */
.rb-navb__caret {
  opacity: 0.45;
  flex-shrink: 0;
  transition: transform 0.2s ease, opacity 0.2s ease;
}
.rb-navb__item--has-drop:hover .rb-navb__caret {
  transform: rotate(180deg);
  opacity: 1;
}

/* ---- dropdown ---- */
.rb-navb__dropdown {
  position: absolute;
  top: 100%;
  left: 0;
  min-width: 200px;
  background: #181818;
  border: 1px solid #2a2a2a;
  border-top: 2px solid #c8f135;
  list-style: none;
  margin: 0;
  padding: 8px 0;
  opacity: 0;
  visibility: hidden;
  transform: translateY(-6px);
  transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
  z-index: 400;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
}

.rb-navb__list--right .rb-navb__dropdown {
  left: auto;
  right: 0;
}

.rb-navb__item--has-drop:hover .rb-navb__dropdown {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

.rb-navb__dropdown-link {
  display: block;
  padding: 10px 20px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.6);
  text-decoration: none;
  transition: color 0.15s ease, background 0.15s ease;
}
.rb-navb__dropdown-link:hover {
  color: #ffffff;
  background: rgba(255, 255, 255, 0.06);
}

/* ---- logo badge — overflows the bar downward only ---- */
.rb-navb__logo {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 36px;
  /* overflow downward into the hero, not upward into announcement bar */
  height: calc(100% + 48px);
  margin-top: -8px;
  margin-bottom: -40px;
  position: relative;
  z-index: 350;
  text-decoration: none;
  mix-blend-mode: screen;
}

.rb-navb__logo-img {
  display: block;
  max-height: 156px;
  width: auto;
  transition: opacity 0.2s ease;
  filter: invert(1);
}
.rb-navb__logo:hover .rb-navb__logo-img {
  opacity: 0.72;
}

/* wordmark fallback when no logo image is set */
.rb-navb__wordmark {
  font-size: 13px;
  font-weight: 900;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #ffffff;
  white-space: nowrap;
  transition: color 0.2s ease;
}
.rb-navb__logo:hover .rb-navb__wordmark {
  color: #c8f135;
}
{% endstylesheet %}

{% schema %}
{
  "name": "RB — Nav Bar",
  "tag": "section",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu",
      "info": "Links are split automatically — first half on the left, second half on the right of the logo"
    }
  ],
  "presets": [
    {
      "name": "RB — Nav Bar",
      "settings": {
        "menu": "main-menu"
      }
    }
  ]
}
{% endschema %}
