
{%- liquid
  assign all_links = linklists[section.settings.menu].links
  assign total     = all_links.size
  assign half      = total | divided_by: 2
-%}

<style>
  #header-group {
    position: sticky !important;
    top: 0 !important;
    z-index: 2147483647 !important;
    background: #000000 !important;
    width: 100%;
  }

  #shopify-section-header_section {
    position: relative !important;
    top: 0 !important;
    z-index: 10001 !important;
  }

  #shopify-section-{{ section.id }} {
    position: relative !important;
    margin-top: 0 !important;
    margin-bottom: 0 !important;
    padding-top: 0 !important;
    padding-bottom: 0 !important;
    z-index: 10000 !important;
  }
</style>

<nav
  class="rb-navb color-scheme-5"
  id="rb-navb-{{ section.id }}"
  aria-label="{{ shop.name }} navigation"
>
  <div class="rb-navb__inner rb-container">

    {%- comment -%} LEFT MENU — first half of links {%- endcomment -%}
    <ul class="rb-navb__list rb-navb__list--left" role="list">
      {%- for link in all_links -%}
        {%- if forloop.index <= half -%}
          <li class="rb-navb__item{% if link.links.size > 0 %} rb-navb__item--has-drop{% endif %}">
            <a
              href="{{ link.url }}"
              class="rb-navb__link{% if link.current %} rb-navb__link--active{% endif %}"
              {% if link.current %}aria-current="page"{% endif %}
            >
              {{- link.title -}}
              {%- if link.links.size > 0 -%}
                <svg class="rb-navb__caret" viewBox="0 0 10 6" fill="none" width="10" height="6">
                  <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              {%- endif -%}
            </a>
            {%- if link.links.size > 0 -%}
              <ul class="rb-navb__dropdown" role="list">
                {%- for child in link.links -%}
                  <li>
                    <a href="{{ child.url }}" class="rb-navb__dropdown-link{% if child.current %} rb-navb__link--active{% endif %}">
                      {{- child.title -}}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>

    {%- comment -%} CENTER LOGO {%- endcomment -%}
    <div class="rb-navb__spacer" aria-hidden="true"></div>
    <a href="{{ routes.root_url }}" class="rb-navb__logo" aria-label="{{ shop.name }} home">
      {%- if settings.logo != blank -%}
        {{- settings.logo
          | image_url: height: 160
          | image_tag:
            alt: shop.name,
            loading: 'eager',
            class: 'rb-navb__logo-img'
        -}}
      {%- else -%}
        <span class="rb-navb__wordmark">{{ shop.name | upcase }}</span>
      {%- endif -%}
    </a>

    {%- comment -%} RIGHT MENU — second half of links {%- endcomment -%}
    <ul class="rb-navb__list rb-navb__list--right" role="list">
      {%- for link in all_links -%}
        {%- if forloop.index > half -%}
          <li class="rb-navb__item{% if link.links.size > 0 %} rb-navb__item--has-drop{% endif %}">
            <a
              href="{{ link.url }}"
              class="rb-navb__link{% if link.current %} rb-navb__link--active{% endif %}{% if link.title == 'Sale' or link.title == 'SALE' or link.title == 'Rebajas' or link.title == 'REBAJAS' %} rb-navb__link--sale{% endif %}"
              {% if link.current %}aria-current="page"{% endif %}
            >
              {{- link.title -}}
              {%- if link.links.size > 0 -%}
                <svg class="rb-navb__caret" viewBox="0 0 10 6" fill="none" width="10" height="6">
                  <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              {%- endif -%}
            </a>
            {%- if link.links.size > 0 -%}
              <ul class="rb-navb__dropdown" role="list">
                {%- for child in link.links -%}
                  <li>
                    <a href="{{ child.url }}" class="rb-navb__dropdown-link{% if child.current %} rb-navb__link--active{% endif %}">
                      {{- child.title -}}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>

  </div>
</nav>

{% stylesheet %}
/* ================================================================
   RB NAV BAR — Rokit-style: items | LOGO badge | items
   Light / white colourway — logo overflows below like Rokit
   ================================================================ */

.rb-navb {
  display: block;
  background: transparent !important; /* Let #header-group handle the background */
  border-bottom: none;
  position: relative;
  --rb-logo-top-size: 112px;
  --rb-logo-scrolled-size: 48px;
  --rb-logo-current-size: var(--rb-logo-top-size);
  z-index: 9999;
  overflow: visible;
}

@media (min-width: 990px) {
  .rb-navb { 
    display: block; 
    position: relative; /* Now handled by #header-group stickiness */
  }
  
  /* Hide default header logo on desktop to avoid overlap */
  .header-logo {
    display: none !important;
  }
}

/* ---- inner grid ---- */
.rb-navb__inner {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  height: 60px;
  overflow: visible;
  position: relative;
}

.rb-navb__spacer {
  width: 180px; /* Space for the logo to prevent menu overlap */
  height: 1px;
  transition: width 0.4s ease;
}

html.rb-navb-scrolled .rb-navb__spacer {
  width: 100px; /* Smaller spacer when logo is small */
}

/* ---- nav lists ---- */
.rb-navb__list {
  display: none;
  align-items: center;
  list-style: none;
  margin: 0;
  padding: 0;
  height: 100%;
}

@media (min-width: 990px) {
  .rb-navb__list { display: flex; }
}

.rb-navb__list--left  { justify-content: flex-end; }
.rb-navb__list--right { justify-content: flex-start; }

/* ---- nav items ---- */
.rb-navb__item {
  position: relative;
  height: 100%;
  display: flex;
  align-items: center;
}

/* ---- nav links ---- */
.rb-navb__link {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 0 20px;
  height: 100%;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.65);
  text-decoration: none;
  white-space: nowrap;
  transition: color 0.2s ease;
  position: relative;
}

/* lime bottom-bar indicator on hover / active */
.rb-navb__link::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20px;
  right: 20px;
  height: 2px;
  background: #c8f135;
  transform: scaleX(0);
  transform-origin: center;
  transition: transform 0.25s ease;
}

.rb-navb__link:hover,
.rb-navb__link--active {
  color: #ffffff;
}

.rb-navb__link:hover::after,
.rb-navb__link--active::after {
  transform: scaleX(1);
}

/* sale */
.rb-navb__link--sale            { color: #ff2d2d !important; }
.rb-navb__link--sale:hover      { color: #cc0000 !important; }
.rb-navb__link--sale::after     { background: #ff2d2d; }

/* ---- caret ---- */
.rb-navb__caret {
  opacity: 0.45;
  flex-shrink: 0;
  transition: transform 0.2s ease, opacity 0.2s ease;
}
.rb-navb__item--has-drop:hover .rb-navb__caret {
  transform: rotate(180deg);
  opacity: 1;
}

/* ---- dropdown ---- */
.rb-navb__dropdown {
  position: absolute;
  top: 100%;
  left: 0;
  min-width: 200px;
  background: #181818;
  border: 1px solid #2a2a2a;
  border-top: 2px solid #c8f135;
  list-style: none;
  margin: 0;
  padding: 8px 0;
  opacity: 0;
  visibility: hidden;
  transform: translateY(-6px);
  transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
  z-index: 400;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
}

.rb-navb__list--right .rb-navb__dropdown {
  left: auto;
  right: 0;
}

.rb-navb__item--has-drop:hover .rb-navb__dropdown {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

.rb-navb__dropdown-link {
  display: block;
  padding: 10px 20px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.6);
  text-decoration: none;
  transition: color 0.15s ease, background 0.15s ease;
}
.rb-navb__dropdown-link:hover {
  color: #ffffff;
  background: rgba(255, 255, 255, 0.06);
}

/* ---- center logo ---- */
.rb-navb__logo {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  height: var(--rb-logo-current-size);
  width: auto;
  position: absolute;
  left: 50%;
  top: 0; /* Center it on the boundary between header and navbar */
  transform: translate(-50%, -50%);
  z-index: 10000;
  text-decoration: none;
  mix-blend-mode: screen;
  transition: height 0.4s cubic-bezier(0.4, 0, 0.2, 1), 
              transform 0.4s cubic-bezier(0.4, 0, 0.2, 1),
              top 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

html.rb-navb-scrolled .rb-navb__logo {
  top: 50%; /* Center it back in the navbar when small */
}

.rb-navb__logo-img {
  display: block;
  max-height: var(--rb-logo-current-size);
  width: auto;
  transition: opacity 0.2s ease, max-height 0.3s ease;
  filter: invert(1);
}
.rb-navb__logo:hover .rb-navb__logo-img {
  opacity: 0.72;
}

/* wordmark fallback when no logo image is set */
.rb-navb__wordmark {
  font-size: 13px;
  font-weight: 900;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #ffffff;
  white-space: nowrap;
  transition: color 0.2s ease;
}
.rb-navb__logo:hover .rb-navb__wordmark {
  color: #c8f135;
}

/* Keep logo large at page top, then shrink when scrolling */
html.rb-navb-scrolled .rb-navb__logo {
  height: var(--rb-logo-scrolled-size);
}

html:not(.rb-navb-scrolled) .rb-navb__logo {
  height: var(--rb-logo-top-size);
}

html.rb-navb-scrolled .rb-navb__logo-img {
  max-height: var(--rb-logo-scrolled-size);
}

html:not(.rb-navb-scrolled) .rb-navb {
  --rb-logo-current-size: var(--rb-logo-top-size);
}

@media (max-width: 989px) {
  .rb-navb {
    background: transparent;
    z-index: 10001; /* Ensure it stays above header on mobile */
  }
  
  .rb-navb__inner {
    height: 60px;
  }

  .rb-navb__spacer {
    display: none;
  }

  .rb-navb__logo {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    height: 64px;
  }

  .rb-navb__logo-img {
    max-height: 64px;
    filter: invert(1);
  }
}
{% endstylesheet %}

<script>
  (() => {
    const scrolledClass = 'rb-navb-scrolled';
    const threshold = 60; // Increased threshold for a smoother feel

    const syncRbNavbarState = () => {
      if (window.scrollY > threshold) {
        document.documentElement.classList.add(scrolledClass);
      } else {
        document.documentElement.classList.remove(scrolledClass);
      }
    };

    syncRbNavbarState();
    document.addEventListener('scroll', syncRbNavbarState, { passive: true });
  })();
</script>

{% schema %}
{
  "name": "RB — Nav Bar",
  "tag": "section",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu",
      "info": "Links are split automatically — first half on the left, second half on the right of the logo"
    }
  ],
  "presets": [
    {
      "name": "RB — Nav Bar",
      "settings": {
        "menu": "main-menu"
      }
    }
  ]
}
{% endschema %}
