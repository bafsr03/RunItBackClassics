
{%- liquid
  assign all_links = linklists[section.settings.menu].links
  assign total     = all_links.size
  assign half      = total | divided_by: 2
-%}

<style>
  /*
   * STICKY STRATEGY
   * ───────────────
   * #header-group is NOT sticky — it just wraps everything.
   * The nav bar section itself is sticky at top:0.
   * The shop strip section is sticky at top:60px (nav bar height).
   * The announcement bar and Horizon header scroll away naturally.
   * No overflow:hidden, no max-height, no JS needed.
   */

  #header-group {
    position: relative !important;
    z-index: 200;
    width: 100%;
  }

  /* Nav bar section: pins to top of viewport when reached */
  #shopify-section-{{ section.id }} {
    position: sticky !important;
    top: 0 !important;
    z-index: 9999 !important;
    background: #000 !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  /* Shop strip: pins just below the nav bar (60px = nav bar height) */
  #shopify-section-rb_shop_strip {
    position: sticky !important;
    top: 60px !important;
    z-index: 9998 !important;
    background: #0d0d0d !important;
  }

  /* Hide Horizon's default header logo — our nav bar has the logo */
  .header__heading-logo,
  .header-logo {
    display: none !important;
  }
</style>

<nav
  class="rb-navb color-scheme-5"
  id="rb-navb-{{ section.id }}"
  aria-label="{{ shop.name }} navigation"
>
  <div class="rb-navb__inner rb-container">

    {%- comment -%} LEFT MENU — first half of links {%- endcomment -%}
    <ul class="rb-navb__list rb-navb__list--left" role="list">
      {%- for link in all_links -%}
        {%- if forloop.index <= half -%}
          <li class="rb-navb__item{% if link.links.size > 0 %} rb-navb__item--has-drop{% endif %}">
            <a
              href="{{ link.url }}"
              class="rb-navb__link{% if link.current %} rb-navb__link--active{% endif %}"
              {% if link.current %}aria-current="page"{% endif %}
            >
              {{- link.title -}}
              {%- if link.links.size > 0 -%}
                <svg class="rb-navb__caret" viewBox="0 0 10 6" fill="none" width="10" height="6">
                  <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              {%- endif -%}
            </a>
            {%- if link.links.size > 0 -%}
              <ul class="rb-navb__dropdown" role="list">
                {%- for child in link.links -%}
                  <li>
                    <a href="{{ child.url }}" class="rb-navb__dropdown-link{% if child.current %} rb-navb__link--active{% endif %}">
                      {{- child.title -}}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>

    {%- comment -%} CENTER — spacer holds logo column width {%- endcomment -%}
    <div class="rb-navb__spacer" aria-hidden="true"></div>

    {%- comment -%} CENTER LOGO — absolute, centered in the nav bar {%- endcomment -%}
    <a href="{{ routes.root_url }}" class="rb-navb__logo" aria-label="{{ shop.name }} home">
      {%- if settings.logo != blank -%}
        {{- settings.logo
          | image_url: height: 160
          | image_tag:
            alt: shop.name,
            loading: 'eager',
            class: 'rb-navb__logo-img'
        -}}
      {%- else -%}
        <span class="rb-navb__wordmark">{{ shop.name | upcase }}</span>
      {%- endif -%}
    </a>

    {%- comment -%} RIGHT MENU — second half of links {%- endcomment -%}
    <ul class="rb-navb__list rb-navb__list--right" role="list">
      {%- for link in all_links -%}
        {%- if forloop.index > half -%}
          <li class="rb-navb__item{% if link.links.size > 0 %} rb-navb__item--has-drop{% endif %}">
            <a
              href="{{ link.url }}"
              class="rb-navb__link{% if link.current %} rb-navb__link--active{% endif %}{% if link.title == 'Sale' or link.title == 'SALE' %} rb-navb__link--sale{% endif %}"
              {% if link.current %}aria-current="page"{% endif %}
            >
              {{- link.title -}}
              {%- if link.links.size > 0 -%}
                <svg class="rb-navb__caret" viewBox="0 0 10 6" fill="none" width="10" height="6">
                  <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              {%- endif -%}
            </a>
            {%- if link.links.size > 0 -%}
              <ul class="rb-navb__dropdown" role="list">
                {%- for child in link.links -%}
                  <li>
                    <a href="{{ child.url }}" class="rb-navb__dropdown-link{% if child.current %} rb-navb__link--active{% endif %}">
                      {{- child.title -}}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>

  </div>
</nav>

{% stylesheet %}
/* ================================================================
   RB NAV BAR
   ================================================================ */

.rb-navb {
  display: block;
  background: #000;
  border-bottom: 1px solid rgba(255,255,255,0.08);
  position: relative;
  z-index: 1;
  overflow: visible;
}

@media (min-width: 990px) {
  .rb-navb { display: block; }
}

/* ── Inner grid: left list | logo spacer | right list ── */
.rb-navb__inner {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  height: 60px;
  overflow: visible;
  position: relative;
}

.rb-navb__spacer {
  width: 160px;
  height: 1px;
  flex-shrink: 0;
}

/* ── Nav lists ── */
.rb-navb__list {
  display: none;
  align-items: center;
  list-style: none;
  margin: 0;
  padding: 0;
  height: 100%;
}

@media (min-width: 990px) {
  .rb-navb__list { display: flex; }
}

.rb-navb__list--left  { justify-content: flex-end; }
.rb-navb__list--right { justify-content: flex-start; }

/* ── Nav items ── */
.rb-navb__item {
  position: relative;
  height: 100%;
  display: flex;
  align-items: center;
}

/* ── Nav links ── */
.rb-navb__link {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 0 18px;
  height: 100%;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.6);
  text-decoration: none;
  white-space: nowrap;
  transition: color 0.2s ease;
  position: relative;
}

.rb-navb__link::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 18px;
  right: 18px;
  height: 2px;
  background: #c8f135;
  transform: scaleX(0);
  transform-origin: center;
  transition: transform 0.22s ease;
}

.rb-navb__link:hover,
.rb-navb__link--active { color: #fff; }

.rb-navb__link:hover::after,
.rb-navb__link--active::after { transform: scaleX(1); }

.rb-navb__link--sale            { color: #ff3030 !important; }
.rb-navb__link--sale:hover      { color: #ff0000 !important; }
.rb-navb__link--sale::after     { background: #ff3030; }

/* ── Caret ── */
.rb-navb__caret {
  opacity: 0.4;
  flex-shrink: 0;
  transition: transform 0.2s ease, opacity 0.2s ease;
}
.rb-navb__item--has-drop:hover .rb-navb__caret {
  transform: rotate(180deg);
  opacity: 1;
}

/* ── Dropdown ── */
.rb-navb__dropdown {
  position: absolute;
  top: 100%;
  left: 0;
  min-width: 200px;
  background: #181818;
  border: 1px solid #222;
  border-top: 2px solid #c8f135;
  list-style: none;
  margin: 0;
  padding: 8px 0;
  opacity: 0;
  visibility: hidden;
  transform: translateY(-6px);
  transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
  z-index: 500;
  box-shadow: 0 8px 32px rgba(0,0,0,0.6);
}

.rb-navb__list--right .rb-navb__dropdown {
  left: auto;
  right: 0;
}

.rb-navb__item--has-drop:hover .rb-navb__dropdown {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

.rb-navb__dropdown-link {
  display: block;
  padding: 10px 20px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.6);
  text-decoration: none;
  transition: color 0.15s ease, background 0.15s ease;
}
.rb-navb__dropdown-link:hover {
  color: #fff;
  background: rgba(255,255,255,0.06);
}

/* ── Logo: absolutely centered in the 60px nav bar, same size always ── */
.rb-navb__logo {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80px;
  width: auto;
  z-index: 10;
  text-decoration: none;
  mix-blend-mode: screen;
}

.rb-navb__logo-img {
  display: block;
  height: 80px;
  width: auto;
  filter: invert(1);
  transition: opacity 0.2s ease;
}

.rb-navb__logo:hover .rb-navb__logo-img { opacity: 0.75; }

.rb-navb__wordmark {
  font-size: 14px;
  font-weight: 900;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #fff;
  white-space: nowrap;
  transition: color 0.2s ease;
}
.rb-navb__logo:hover .rb-navb__wordmark { color: #c8f135; }

/* ── Mobile ── */
@media (max-width: 989px) {
  .rb-navb { background: #000; }
  .rb-navb__spacer { display: none; }

  .rb-navb__logo {
    height: 52px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .rb-navb__logo-img { height: 52px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "RB — Nav Bar",
  "tag": "section",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu",
      "info": "Links split automatically — first half left of logo, second half right"
    }
  ],
  "presets": [
    {
      "name": "RB — Nav Bar",
      "settings": { "menu": "main-menu" }
    }
  ]
}
{% endschema %}
