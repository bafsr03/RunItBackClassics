<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap" rel="stylesheet">

<section class="rb-about" id="rb-about-{{ section.id }}">

  <!-- BG -->
  <div class="rb-about__bg" aria-hidden="true">
    <div class="rb-about__bg-grid"></div>
    <div class="rb-about__bg-glow rb-about__bg-glow--1"></div>
    <div class="rb-about__bg-glow rb-about__bg-glow--2"></div>
  </div>

  <!-- HERO HEADER -->
  <div class="rb-about__hero">
    <div class="rb-container">
      <p class="rb-about__eyebrow">{{ section.settings.eyebrow }}</p>
      <h1 class="rb-about__title">{{ section.settings.title }}</h1>
      <p class="rb-about__subtitle">{{ section.settings.subtitle }}</p>
    </div>
  </div>

  <!-- STORY + PHOTO -->
  <div class="rb-container rb-about__story">
    <div class="rb-about__story-text">
      <div class="rb-about__story-block">
        <h2 class="rb-about__section-title">{{ section.settings.story_heading }}</h2>
        <div class="rb-about__prose">{{ section.settings.story_body }}</div>
      </div>
      <div class="rb-about__story-block">
        <h2 class="rb-about__section-title">{{ section.settings.mission_heading }}</h2>
        <div class="rb-about__prose">{{ section.settings.mission_body }}</div>
      </div>
    </div>

    <div class="rb-about__story-photos">
      {%- if section.settings.photo_1 != blank -%}
        <div class="rb-about__sp rb-about__sp--1">
          <img src="{{ section.settings.photo_1 | image_url: width: 700 }}"
               alt="{{ section.settings.photo_1_alt | default: 'Runitback Classics' }}"
               loading="lazy" width="700" height="900">
        </div>
      {%- else -%}
        <div class="rb-about__sp rb-about__sp--1 rb-about__sp--placeholder">
          <span>PHOTO 1</span>
        </div>
      {%- endif -%}
      {%- if section.settings.photo_2 != blank -%}
        <div class="rb-about__sp rb-about__sp--2">
          <img src="{{ section.settings.photo_2 | image_url: width: 700 }}"
               alt="{{ section.settings.photo_2_alt | default: 'Runitback Classics' }}"
               loading="lazy" width="700" height="600">
        </div>
      {%- else -%}
        <div class="rb-about__sp rb-about__sp--2 rb-about__sp--placeholder">
          <span>PHOTO 2</span>
        </div>
      {%- endif -%}
    </div>
  </div>

  <!-- STAT STRIP -->
  <div class="rb-about__stats-wrap">
    <div class="rb-container rb-about__stats">
      <div class="rb-about__stat">
        <strong>500+</strong>
        <span>Unique Items</span>
      </div>
      <div class="rb-about__stat-div" aria-hidden="true"></div>
      <div class="rb-about__stat">
        <strong>100%</strong>
        <span>Authenticated</span>
      </div>
      <div class="rb-about__stat-div" aria-hidden="true"></div>
      <div class="rb-about__stat">
        <strong>EST. 2024</strong>
        <span>Abilene, TX</span>
      </div>
      <div class="rb-about__stat-div" aria-hidden="true"></div>
      <div class="rb-about__stat">
        <strong>5★</strong>
        <span>Rated</span>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════ -->
  <!-- ON THE ROAD: EVENTS SECTION                        -->
  <!-- ═══════════════════════════════════════════════════ -->
  <div class="rb-about__events">
    <div class="rb-container">

      <div class="rb-about__events-hd rb-reveal">
        <p class="rb-about__eyebrow">THE JOURNEY</p>
        <h2 class="rb-about__events-title">ON THE ROAD</h2>
        <p class="rb-about__events-sub">From Abilene to Texas's biggest sneaker stages — Runitback Classics is taking it to the culture.</p>
      </div>

      <div class="rb-about__events-grid">

        <!-- Event 1: SneakerCon San Antonio 2026 -->
        <div class="rb-about__event rb-reveal rb-reveal--delay-1">
          <div class="rb-about__event-img-wrap">
            {%- if section.settings.event_photo_1 != blank -%}
              <img src="{{ section.settings.event_photo_1 | image_url: width: 900 }}"
                   alt="{{ section.settings.event_photo_1_alt | default: 'SneakerCon San Antonio 2026 — Runitback Classics booth' }}"
                   loading="lazy" width="900" height="1100">
            {%- else -%}
              <div class="rb-about__event-placeholder"><span>EVENT PHOTO</span></div>
            {%- endif -%}
            <div class="rb-about__event-img-overlay">
              <div class="rb-about__event-tags">
                <span class="rb-about__event-tag">SNEAKERCON</span>
                <span class="rb-about__event-tag rb-about__event-tag--lime">SAN ANTONIO · 2026</span>
              </div>
            </div>
          </div>
          <div class="rb-about__event-body">
            <div class="rb-about__event-header">
              <h3 class="rb-about__event-name">SNEAKERCON<br><em>SAN ANTONIO</em></h3>
              <div class="rb-about__event-year-badge">2026</div>
            </div>
            <p class="rb-about__event-desc">{{ section.settings.event_1_caption | default: 'Reps from the 325 — we pulled up to SneakerCon San Antonio 2026 with heat on every table. Jordans, Dunks, Bapes, vintage gems stacked sky-high. The culture showed out and the RB booth held it down.' }}</p>
          </div>
        </div>

        <!-- Event 2: SneakerCon Houston 2026 -->
        <div class="rb-about__event rb-reveal rb-reveal--delay-2">
          <div class="rb-about__event-img-wrap">
            {%- if section.settings.event_photo_2 != blank -%}
              <img src="{{ section.settings.event_photo_2 | image_url: width: 900 }}"
                   alt="{{ section.settings.event_photo_2_alt | default: 'SneakerCon Houston 2026 — Runitback Classics booth' }}"
                   loading="lazy" width="900" height="600">
            {%- else -%}
              <div class="rb-about__event-placeholder"><span>EVENT PHOTO</span></div>
            {%- endif -%}
            <div class="rb-about__event-img-overlay">
              <div class="rb-about__event-tags">
                <span class="rb-about__event-tag">SNEAKERCON</span>
                <span class="rb-about__event-tag rb-about__event-tag--lime">HOUSTON · 2026</span>
              </div>
            </div>
          </div>
          <div class="rb-about__event-body">
            <div class="rb-about__event-header">
              <h3 class="rb-about__event-name">SNEAKERCON<br><em>HOUSTON</em></h3>
              <div class="rb-about__event-year-badge">2026</div>
            </div>
            <p class="rb-about__event-desc">{{ section.settings.event_2_caption | default: 'H-Town, we see you. SneakerCon Houston 2026 was a statement — banner flying, table packed wall to wall, and we connected with sneakerheads across the state. The RB movement is growing.' }}</p>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- INFO CARDS -->
  <div class="rb-container rb-about__cards">

    <div class="rb-about__card">
      <div class="rb-about__card-icon">📍</div>
      <h3 class="rb-about__card-title">FIND US</h3>
      <p>3234 S 27th St<br>Abilene, TX 79605</p>
      <a href="https://maps.google.com/?q=3234+S+27th+St+Abilene+TX+79605" target="_blank" rel="noopener" class="rb-about__card-link">Get Directions →</a>
    </div>

    <div class="rb-about__card">
      <div class="rb-about__card-icon">🕐</div>
      <h3 class="rb-about__card-title">STORE HOURS</h3>
      <p>Mon – Fri: 12PM – 6PM<br>Saturday: 12PM – 5PM<br>Sunday: Closed</p>
    </div>

    <div class="rb-about__card rb-about__card--lime">
      <div class="rb-about__card-icon">🔥</div>
      <h3 class="rb-about__card-title">THIRSTY THURSDAY</h3>
      <p>Live auctions every Thursday at 6:35PM on Instagram. Rare sneakers, vintage gems — first comment wins.</p>
      <a href="https://www.instagram.com/runitbackclassicsllc" target="_blank" rel="noopener" class="rb-about__card-link">@runitbackclassicsllc →</a>
    </div>

    <div class="rb-about__card">
      <div class="rb-about__card-icon">🤝</div>
      <h3 class="rb-about__card-title">BUY · SELL · TRADE</h3>
      <p>Bring your kicks, vintage tees, streetwear, or trading cards in-store or DM us on Instagram to set up a deal.</p>
      <a href="/pages/contact" class="rb-about__card-link">Contact Us →</a>
    </div>

  </div>

  <!-- ═══════════════════════════════════════════════════ -->
  <!-- COMMUNITY / THE FAMILY SECTION                     -->
  <!-- ═══════════════════════════════════════════════════ -->
  <div class="rb-about__community">
    <div class="rb-container">

      <div class="rb-about__community-hd rb-reveal">
        <p class="rb-about__eyebrow">THE FAMILY</p>
        <h2 class="rb-about__community-title">MORE THAN A STORE</h2>
        <p class="rb-about__community-sub">We give back, show up, and build with the community that built us.</p>
      </div>

      <div class="rb-about__community-grid">

        <!-- Left: tall feature (backpack drive / giving back) -->
        <div class="rb-about__cm rb-about__cm--feature rb-reveal rb-reveal--delay-1">
          <div class="rb-about__cm-inner">
            {%- if section.settings.community_photo_1 != blank -%}
              <img src="{{ section.settings.community_photo_1 | image_url: width: 800 }}"
                   alt="{{ section.settings.community_photo_1_alt | default: 'Runitback Classics community backpack drive' }}"
                   loading="lazy" width="800" height="1000">
            {%- else -%}
              <div class="rb-about__cm-placeholder"><span>COMMUNITY PHOTO</span></div>
            {%- endif -%}
            <div class="rb-about__cm-overlay">
              <span class="rb-about__cm-label">GIVING BACK</span>
              <p class="rb-about__cm-caption">{{ section.settings.community_caption_1 | default: 'Back-to-school backpack drive — giving back to the kids and the community that supports us every day.' }}</p>
            </div>
          </div>
        </div>

        <!-- Right: two stacked (customers + origins) -->
        <div class="rb-about__cm-stack">

          <div class="rb-about__cm rb-reveal rb-reveal--delay-2">
            <div class="rb-about__cm-inner">
              {%- if section.settings.community_photo_2 != blank -%}
                <img src="{{ section.settings.community_photo_2 | image_url: width: 800 }}"
                     alt="{{ section.settings.community_photo_2_alt | default: 'Runitback Classics happy customers with vintage finds' }}"
                     loading="lazy" width="800" height="600">
              {%- else -%}
                <div class="rb-about__cm-placeholder"><span>CUSTOMER PHOTO</span></div>
              {%- endif -%}
              <div class="rb-about__cm-overlay">
                <span class="rb-about__cm-label">THE FINDS</span>
                <p class="rb-about__cm-caption">{{ section.settings.community_caption_2 | default: 'Happy customers scoring rare vintage tees and classic kicks straight from the RB rack.' }}</p>
              </div>
            </div>
          </div>

          <div class="rb-about__cm rb-reveal rb-reveal--delay-3">
            <div class="rb-about__cm-inner">
              {%- if section.settings.community_photo_3 != blank -%}
                <img src="{{ section.settings.community_photo_3 | image_url: width: 800 }}"
                     alt="{{ section.settings.community_photo_3_alt | default: 'Runitback Classics humble beginnings garage days' }}"
                     loading="lazy" width="800" height="600">
              {%- else -%}
                <div class="rb-about__cm-placeholder"><span>ORIGINS PHOTO</span></div>
              {%- endif -%}
              <div class="rb-about__cm-overlay">
                <span class="rb-about__cm-label">WHERE IT STARTED</span>
                <p class="rb-about__cm-caption">{{ section.settings.community_caption_3 | default: 'The garage days — where the hustle and the vision that became Runitback Classics was born.' }}</p>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>

  <!-- PHOTO THIRD (optional) -->
  {%- if section.settings.photo_3 != blank -%}
  <div class="rb-about__full-photo">
    <img src="{{ section.settings.photo_3 | image_url: width: 1400 }}"
         alt="{{ section.settings.photo_3_alt | default: 'Runitback Classics' }}"
         loading="lazy" width="1400" height="600">
    <div class="rb-about__full-photo-overlay">
      <p class="rb-about__fp-label">RUNITBACK CLASSICS · ABILENE TX · EST. 2024</p>
    </div>
  </div>
  {%- endif -%}

  <!-- BOTTOM CTA -->
  <div class="rb-container rb-about__bottom-cta">
    <h2 class="rb-about__bottom-title">READY TO SHOP?</h2>
    <p class="rb-about__bottom-sub">Browse our latest drops or get in touch — we'd love to hear from you.</p>
    <div class="rb-about__bottom-btns">
      <a href="/collections/all" class="rb-btn rb-btn--lime">SHOP ALL DROPS</a>
      <a href="/pages/contact" class="rb-btn rb-btn--ghost">CONTACT US</a>
    </div>
  </div>

</section>

<style>
  .rb-about {
    position: relative;
    background: var(--rb-dark, #101010);
    overflow: hidden;
  }

  .rb-about__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .rb-about__bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(200,241,53,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(200,241,53,0.025) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .rb-about__bg-glow {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }

  .rb-about__bg-glow--1 {
    width: 700px; height: 700px;
    background: radial-gradient(circle, rgba(200,241,53,0.06) 0%, transparent 70%);
    top: -200px; right: -150px;
  }

  .rb-about__bg-glow--2 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(200,241,53,0.04) 0%, transparent 70%);
    bottom: 100px; left: -100px;
  }

  /* ---- Hero header ---- */
  .rb-about__hero {
    position: relative;
    z-index: 1;
    padding-block: 110px 80px;
    text-align: center;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  .rb-about__eyebrow {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--rb-lime, #c8f135);
    border: 1px solid rgba(200,241,53,0.3);
    display: inline-block;
    padding: 6px 16px;
    border-radius: 100px;
    margin: 0 0 20px;
    width: fit-content;
  }

  .rb-about__title {
    font-family: 'Bebas Neue', 'Impact', sans-serif;
    font-size: clamp(52px, 9vw, 110px);
    font-weight: 400;
    line-height: 0.95;
    color: #fff;
    margin: 0 0 20px;
  }

  .rb-about__subtitle {
    color: rgba(255,255,255,0.5);
    font-size: 17px;
    line-height: 1.65;
    max-width: 560px;
    margin: 0 auto;
  }

  /* ---- Story ---- */
  .rb-about__story {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 60px;
    padding-block: 80px;
  }

  @media (min-width: 1024px) {
    .rb-about__story {
      flex-direction: row;
      align-items: flex-start;
      gap: 80px;
    }
  }

  .rb-about__story-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .rb-about__section-title {
    font-family: 'Bebas Neue', 'Impact', sans-serif;
    font-size: 32px;
    font-weight: 400;
    color: #fff;
    margin: 0 0 14px;
    letter-spacing: 0.04em;
  }

  .rb-about__prose {
    color: rgba(255,255,255,0.6);
    font-size: 15px;
    line-height: 1.8;
  }

  .rb-about__story-photos {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    max-width: 520px;
  }

  .rb-about__sp {
    border-radius: 12px;
    overflow: hidden;
  }

  .rb-about__sp img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .rb-about__sp:hover img { transform: scale(1.04); }

  .rb-about__sp--1 { aspect-ratio: 3/4; }
  .rb-about__sp--2 { aspect-ratio: 3/4; margin-top: 40px; }

  .rb-about__sp--placeholder {
    background: var(--rb-surface, #181818);
    border: 1px dashed rgba(200,241,53,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .rb-about__sp--placeholder span {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.2em;
    color: rgba(200,241,53,0.3);
  }

  /* ---- Stat strip ---- */
  .rb-about__stats-wrap {
    position: relative;
    z-index: 1;
    background: var(--rb-surface, #181818);
    border-top: 1px solid rgba(255,255,255,0.05);
    border-bottom: 1px solid rgba(255,255,255,0.05);
    padding-block: 48px;
  }

  .rb-about__stats {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0;
  }

  .rb-about__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 16px 40px;
  }

  .rb-about__stat strong {
    font-family: 'Bebas Neue', 'Impact', sans-serif;
    font-size: 40px;
    font-weight: 400;
    color: var(--rb-lime, #c8f135);
    line-height: 1;
  }

  .rb-about__stat span {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
  }

  .rb-about__stat-div {
    width: 1px;
    height: 40px;
    background: rgba(255,255,255,0.08);
    align-self: center;
  }

  @media (max-width: 640px) {
    .rb-about__stat-div { display: none; }
    .rb-about__stat { padding: 12px 24px; }
  }

  /* ══════════════════════════════════════════════ */
  /* EVENTS / ON THE ROAD                          */
  /* ══════════════════════════════════════════════ */
  .rb-about__events {
    position: relative;
    z-index: 1;
    padding-block: 100px;
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  .rb-about__events-hd {
    text-align: center;
    margin-bottom: 64px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .rb-about__events-title {
    font-family: 'Bebas Neue', 'Impact', sans-serif;
    font-size: clamp(44px, 7vw, 84px);
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 0.95;
  }

  .rb-about__events-sub {
    color: rgba(255,255,255,0.5);
    font-size: 16px;
    max-width: 520px;
    line-height: 1.65;
    margin: 0;
  }

  .rb-about__events-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    align-items: start;
  }

  @media (max-width: 768px) {
    .rb-about__events-grid { grid-template-columns: 1fr; }
  }

  .rb-about__event {
    background: var(--rb-surface, #181818);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 20px;
    overflow: hidden;
    transition: border-color 0.35s ease, transform 0.35s ease, box-shadow 0.35s ease;
  }

  .rb-about__event:hover {
    border-color: rgba(200,241,53,0.22);
    transform: translateY(-5px);
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
  }

  .rb-about__event-img-wrap {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
  }

  .rb-about__event-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform 0.65s ease;
  }

  .rb-about__event:hover .rb-about__event-img-wrap img {
    transform: scale(1.05);
  }

  .rb-about__event-placeholder {
    width: 100%;
    aspect-ratio: 4/3;
    background: #161616;
    border-bottom: 1px dashed rgba(200,241,53,0.12);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .rb-about__event-placeholder span {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.22em;
    color: rgba(200,241,53,0.2);
  }

  .rb-about__event-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(8,8,8,0.9) 0%, transparent 55%);
    display: flex;
    align-items: flex-end;
    padding: 20px;
    pointer-events: none;
  }

  .rb-about__event-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .rb-about__event-tag {
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.65);
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.1);
    padding: 5px 12px;
    border-radius: 100px;
    backdrop-filter: blur(10px);
  }

  .rb-about__event-tag--lime {
    color: var(--rb-lime, #c8f135);
    background: rgba(200,241,53,0.1);
    border-color: rgba(200,241,53,0.28);
  }

  .rb-about__event-body {
    padding: 26px 24px 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .rb-about__event-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
  }

  .rb-about__event-name {
    font-family: 'Bebas Neue', 'Impact', sans-serif;
    font-size: 28px;
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 1.05;
    letter-spacing: 0.03em;
  }

  .rb-about__event-name em {
    font-style: normal;
    color: var(--rb-lime, #c8f135);
  }

  .rb-about__event-year-badge {
    font-family: 'Bebas Neue', 'Impact', sans-serif;
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.1em;
    color: var(--rb-lime, #c8f135);
    border: 1px solid rgba(200,241,53,0.32);
    padding: 5px 14px;
    border-radius: 100px;
    white-space: nowrap;
    flex-shrink: 0;
    margin-top: 3px;
  }

  .rb-about__event-desc {
    color: rgba(255,255,255,0.55);
    font-size: 14px;
    line-height: 1.8;
    margin: 0;
  }

  /* ══════════════════════════════════════════════ */
  /* COMMUNITY / THE FAMILY                        */
  /* ══════════════════════════════════════════════ */
  .rb-about__community {
    position: relative;
    z-index: 1;
    padding-block: 100px;
    border-top: 1px solid rgba(255,255,255,0.05);
    background: linear-gradient(180deg, transparent 0%, rgba(200,241,53,0.015) 50%, transparent 100%);
  }

  .rb-about__community-hd {
    text-align: center;
    margin-bottom: 64px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .rb-about__community-title {
    font-family: 'Bebas Neue', 'Impact', sans-serif;
    font-size: clamp(44px, 7vw, 84px);
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 0.95;
  }

  .rb-about__community-sub {
    color: rgba(255,255,255,0.5);
    font-size: 16px;
    max-width: 480px;
    line-height: 1.65;
    margin: 0;
  }

  .rb-about__community-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    align-items: stretch;
  }

  @media (max-width: 768px) {
    .rb-about__community-grid { grid-template-columns: 1fr; }
  }

  .rb-about__cm-stack {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .rb-about__cm {
    border-radius: 16px;
    overflow: hidden;
  }

  .rb-about__cm--feature {
    height: 100%;
  }

  .rb-about__cm--feature .rb-about__cm-inner {
    aspect-ratio: unset;
    height: 100%;
    min-height: 340px;
  }

  .rb-about__cm-inner {
    position: relative;
    overflow: hidden;
    border-radius: 16px;
    aspect-ratio: 4/3;
    border: 1px solid rgba(255,255,255,0.05);
  }

  .rb-about__cm-inner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.65s ease;
  }

  .rb-about__cm:hover .rb-about__cm-inner img {
    transform: scale(1.05);
  }

  .rb-about__cm-placeholder {
    width: 100%;
    height: 100%;
    min-height: 200px;
    background: #161616;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .rb-about__cm-placeholder span {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.22em;
    color: rgba(200,241,53,0.2);
  }

  .rb-about__cm-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(8,8,8,0.92) 0%, rgba(8,8,8,0.15) 55%, transparent 80%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 22px;
    gap: 6px;
    transition: background 0.3s ease;
  }

  .rb-about__cm:hover .rb-about__cm-overlay {
    background: linear-gradient(to top, rgba(8,8,8,0.95) 0%, rgba(8,8,8,0.3) 60%, transparent 85%);
  }

  .rb-about__cm-label {
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--rb-lime, #c8f135);
    display: block;
  }

  .rb-about__cm-caption {
    font-size: 13px;
    color: rgba(255,255,255,0.7);
    line-height: 1.6;
    margin: 0;
    transform: translateY(5px);
    opacity: 0.8;
    transition: transform 0.35s ease, opacity 0.35s ease;
  }

  .rb-about__cm:hover .rb-about__cm-caption {
    transform: translateY(0);
    opacity: 1;
  }

  /* ---- Info cards ---- */
  .rb-about__cards {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    padding-block: 80px;
  }

  @media (min-width: 900px) {
    .rb-about__cards { grid-template-columns: repeat(4, 1fr); }
  }

  @media (max-width: 540px) {
    .rb-about__cards { grid-template-columns: 1fr; }
  }

  .rb-about__card {
    background: var(--rb-surface, #181818);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 16px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: border-color 0.25s ease;
  }

  .rb-about__card:hover {
    border-color: rgba(200,241,53,0.2);
  }

  .rb-about__card--lime {
    background: rgba(200,241,53,0.05);
    border-color: rgba(200,241,53,0.15);
  }

  .rb-about__card-icon {
    font-size: 28px;
    line-height: 1;
  }

  .rb-about__card-title {
    font-family: 'Bebas Neue', 'Impact', sans-serif;
    font-size: 20px;
    font-weight: 400;
    color: #fff;
    letter-spacing: 0.04em;
    margin: 0;
  }

  .rb-about__card p {
    color: rgba(255,255,255,0.55);
    font-size: 14px;
    line-height: 1.7;
    margin: 0;
  }

  .rb-about__card-link {
    color: var(--rb-lime, #c8f135);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
    margin-top: auto;
    transition: opacity 0.2s;
  }

  .rb-about__card-link:hover { opacity: 0.75; }

  /* ---- Full-width photo ---- */
  .rb-about__full-photo {
    position: relative;
    z-index: 1;
    height: 420px;
    overflow: hidden;
  }

  .rb-about__full-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .rb-about__full-photo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(8,8,8,0.7) 0%, transparent 60%);
    display: flex;
    align-items: flex-end;
    padding: 32px 40px;
  }

  .rb-about__fp-label {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin: 0;
  }

  /* ---- Bottom CTA ---- */
  .rb-about__bottom-cta {
    position: relative;
    z-index: 1;
    text-align: center;
    padding-block: 80px 100px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .rb-about__bottom-title {
    font-family: 'Bebas Neue', 'Impact', sans-serif;
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 1;
  }

  .rb-about__bottom-sub {
    color: rgba(255,255,255,0.5);
    font-size: 16px;
    margin: 0;
    max-width: 440px;
  }

  .rb-about__bottom-btns {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    margin-top: 8px;
  }

  /* ══════════════════════════════════════════════ */
  /* SCROLL REVEAL                                 */
  /* ══════════════════════════════════════════════ */
  .rb-reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .rb-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .rb-reveal--delay-1 { transition-delay: 0.08s; }
  .rb-reveal--delay-2 { transition-delay: 0.2s; }
  .rb-reveal--delay-3 { transition-delay: 0.32s; }

  @media (prefers-reduced-motion: reduce) {
    .rb-reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
(function () {
  var section = document.getElementById('rb-about-{{ section.id }}');
  if (!section) return;
  var els = section.querySelectorAll('.rb-reveal');
  if (!els.length) return;

  if (!window.IntersectionObserver) {
    els.forEach(function (el) { el.classList.add('is-visible'); });
    return;
  }

  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) {
        e.target.classList.add('is-visible');
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.12 });

  els.forEach(function (el) { io.observe(el); });
})();
</script>

