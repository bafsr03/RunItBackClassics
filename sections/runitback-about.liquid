<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap" rel="stylesheet">

<section class="rb-about" id="rb-about-{{ section.id }}">

  <!-- BG -->
  <div class="rb-about__bg" aria-hidden="true">
    <div class="rb-about__bg-grid"></div>
    <div class="rb-about__bg-glow rb-about__bg-glow--1"></div>
    <div class="rb-about__bg-glow rb-about__bg-glow--2"></div>
  </div>

  <!-- HERO HEADER -->
  <div class="rb-about__hero">
    <div class="rb-container">
      <p class="rb-about__eyebrow">{{ section.settings.eyebrow }}</p>
      <h1 class="rb-about__title">{{ section.settings.title }}</h1>
      <p class="rb-about__subtitle">{{ section.settings.subtitle }}</p>
    </div>
  </div>

  <!-- STORY + PHOTO -->
  <div class="rb-container rb-about__story">
    <div class="rb-about__story-text">
      <div class="rb-about__story-block">
        <h2 class="rb-about__section-title">{{ section.settings.story_heading }}</h2>
        <div class="rb-about__prose">{{ section.settings.story_body }}</div>
      </div>
      <div class="rb-about__story-block">
        <h2 class="rb-about__section-title">{{ section.settings.mission_heading }}</h2>
        <div class="rb-about__prose">{{ section.settings.mission_body }}</div>
      </div>
    </div>

    <div class="rb-about__story-photos">
      {%- if section.settings.photo_1 != blank -%}
        <div class="rb-about__sp rb-about__sp--1">
          <img src="{{ section.settings.photo_1 | image_url: width: 700 }}"
               alt="{{ section.settings.photo_1_alt | default: 'Runitback Classics' }}"
               loading="lazy" width="700" height="900">
        </div>
      {%- else -%}
        <div class="rb-about__sp rb-about__sp--1 rb-about__sp--placeholder">
          <span>PHOTO 1</span>
        </div>
      {%- endif -%}
      {%- if section.settings.photo_2 != blank -%}
        <div class="rb-about__sp rb-about__sp--2">
          <img src="{{ section.settings.photo_2 | image_url: width: 700 }}"
               alt="{{ section.settings.photo_2_alt | default: 'Runitback Classics' }}"
               loading="lazy" width="700" height="600">
        </div>
      {%- else -%}
        <div class="rb-about__sp rb-about__sp--2 rb-about__sp--placeholder">
          <span>PHOTO 2</span>
        </div>
      {%- endif -%}
    </div>
  </div>

  <!-- STAT STRIP -->
  <div class="rb-about__stats-wrap">
    <div class="rb-container rb-about__stats">
      <div class="rb-about__stat">
        <strong>500+</strong>
        <span>Unique Items</span>
      </div>
      <div class="rb-about__stat-div" aria-hidden="true"></div>
      <div class="rb-about__stat">
        <strong>100%</strong>
        <span>Authenticated</span>
      </div>
      <div class="rb-about__stat-div" aria-hidden="true"></div>
      <div class="rb-about__stat">
        <strong>EST. 2024</strong>
        <span>Abilene, TX</span>
      </div>
      <div class="rb-about__stat-div" aria-hidden="true"></div>
      <div class="rb-about__stat">
        <strong>5★</strong>
        <span>Rated</span>
      </div>
    </div>
  </div>

  <!-- INFO CARDS -->
  <div class="rb-container rb-about__cards">

    <div class="rb-about__card">
      <div class="rb-about__card-icon">📍</div>
      <h3 class="rb-about__card-title">FIND US</h3>
      <p>3234 S 27th St<br>Abilene, TX 79605</p>
      <a href="https://maps.google.com/?q=3234+S+27th+St+Abilene+TX+79605" target="_blank" rel="noopener" class="rb-about__card-link">Get Directions →</a>
    </div>

    <div class="rb-about__card">
      <div class="rb-about__card-icon">🕐</div>
      <h3 class="rb-about__card-title">STORE HOURS</h3>
      <p>Mon – Fri: 12PM – 6PM<br>Saturday: 12PM – 5PM<br>Sunday: Closed</p>
    </div>

    <div class="rb-about__card rb-about__card--lime">
      <div class="rb-about__card-icon">🔥</div>
      <h3 class="rb-about__card-title">THIRSTY THURSDAY</h3>
      <p>Live auctions every Thursday at 6:35PM on Instagram. Rare sneakers, vintage gems — first comment wins.</p>
      <a href="https://www.instagram.com/runitbackclassicsllc" target="_blank" rel="noopener" class="rb-about__card-link">@runitbackclassicsllc →</a>
    </div>

    <div class="rb-about__card">
      <div class="rb-about__card-icon">🤝</div>
      <h3 class="rb-about__card-title">BUY · SELL · TRADE</h3>
      <p>Bring your kicks, vintage tees, streetwear, or trading cards in-store or DM us on Instagram to set up a deal.</p>
      <a href="/pages/contact" class="rb-about__card-link">Contact Us →</a>
    </div>

  </div>

  <!-- PHOTO THIRD (optional) -->
  {%- if section.settings.photo_3 != blank -%}
  <div class="rb-about__full-photo">
    <img src="{{ section.settings.photo_3 | image_url: width: 1400 }}"
         alt="{{ section.settings.photo_3_alt | default: 'Runitback Classics' }}"
         loading="lazy" width="1400" height="600">
    <div class="rb-about__full-photo-overlay">
      <p class="rb-about__fp-label">RUNITBACK CLASSICS · ABILENE TX · EST. 2024</p>
    </div>
  </div>
  {%- endif -%}

  <!-- BOTTOM CTA -->
  <div class="rb-container rb-about__bottom-cta">
    <h2 class="rb-about__bottom-title">READY TO SHOP?</h2>
    <p class="rb-about__bottom-sub">Browse our latest drops or get in touch — we'd love to hear from you.</p>
    <div class="rb-about__bottom-btns">
      <a href="/collections/all" class="rb-btn rb-btn--lime">SHOP ALL DROPS</a>
      <a href="/pages/contact" class="rb-btn rb-btn--ghost">CONTACT US</a>
    </div>
  </div>

</section>

<style>
  .rb-about {
    position: relative;
    background: var(--rb-dark, #101010);
    overflow: hidden;
  }

  .rb-about__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .rb-about__bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(200,241,53,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(200,241,53,0.025) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .rb-about__bg-glow {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }

  .rb-about__bg-glow--1 {
    width: 700px; height: 700px;
    background: radial-gradient(circle, rgba(200,241,53,0.06) 0%, transparent 70%);
    top: -200px; right: -150px;
  }

  .rb-about__bg-glow--2 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(200,241,53,0.04) 0%, transparent 70%);
    bottom: 100px; left: -100px;
  }

  /* ---- Hero header ---- */
  .rb-about__hero {
    position: relative;
    z-index: 1;
    padding-block: 110px 80px;
    text-align: center;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  .rb-about__eyebrow {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--rb-lime, #c8f135);
    border: 1px solid rgba(200,241,53,0.3);
    display: inline-block;
    padding: 6px 16px;
    border-radius: 100px;
    margin: 0 0 20px;
    width: fit-content;
  }

  .rb-about__title {
    font-family: 'Bebas Neue', 'Impact', sans-serif;
    font-size: clamp(52px, 9vw, 110px);
    font-weight: 400;
    line-height: 0.95;
    color: #fff;
    margin: 0 0 20px;
  }

  .rb-about__subtitle {
    color: rgba(255,255,255,0.5);
    font-size: 17px;
    line-height: 1.65;
    max-width: 560px;
    margin: 0 auto;
  }

  /* ---- Story ---- */
  .rb-about__story {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 60px;
    padding-block: 80px;
  }

  @media (min-width: 1024px) {
    .rb-about__story {
      flex-direction: row;
      align-items: flex-start;
      gap: 80px;
    }
  }

  .rb-about__story-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .rb-about__section-title {
    font-family: 'Bebas Neue', 'Impact', sans-serif;
    font-size: 32px;
    font-weight: 400;
    color: #fff;
    margin: 0 0 14px;
    letter-spacing: 0.04em;
  }

  .rb-about__prose {
    color: rgba(255,255,255,0.6);
    font-size: 15px;
    line-height: 1.8;
  }

  .rb-about__story-photos {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    max-width: 520px;
  }

  .rb-about__sp {
    border-radius: 12px;
    overflow: hidden;
  }

  .rb-about__sp img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .rb-about__sp:hover img { transform: scale(1.04); }

  .rb-about__sp--1 { aspect-ratio: 3/4; }
  .rb-about__sp--2 { aspect-ratio: 3/4; margin-top: 40px; }

  .rb-about__sp--placeholder {
    background: var(--rb-surface, #181818);
    border: 1px dashed rgba(200,241,53,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .rb-about__sp--placeholder span {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.2em;
    color: rgba(200,241,53,0.3);
  }

  /* ---- Stat strip ---- */
  .rb-about__stats-wrap {
    position: relative;
    z-index: 1;
    background: var(--rb-surface, #181818);
    border-top: 1px solid rgba(255,255,255,0.05);
    border-bottom: 1px solid rgba(255,255,255,0.05);
    padding-block: 48px;
  }

  .rb-about__stats {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0;
  }

  .rb-about__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 16px 40px;
  }

  .rb-about__stat strong {
    font-family: 'Bebas Neue', 'Impact', sans-serif;
    font-size: 40px;
    font-weight: 400;
    color: var(--rb-lime, #c8f135);
    line-height: 1;
  }

  .rb-about__stat span {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
  }

  .rb-about__stat-div {
    width: 1px;
    height: 40px;
    background: rgba(255,255,255,0.08);
    align-self: center;
  }

  @media (max-width: 640px) {
    .rb-about__stat-div { display: none; }
    .rb-about__stat { padding: 12px 24px; }
  }

  /* ---- Info cards ---- */
  .rb-about__cards {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    padding-block: 80px;
  }

  @media (min-width: 900px) {
    .rb-about__cards { grid-template-columns: repeat(4, 1fr); }
  }

  @media (max-width: 540px) {
    .rb-about__cards { grid-template-columns: 1fr; }
  }

  .rb-about__card {
    background: var(--rb-surface, #181818);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 16px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: border-color 0.25s ease;
  }

  .rb-about__card:hover {
    border-color: rgba(200,241,53,0.2);
  }

  .rb-about__card--lime {
    background: rgba(200,241,53,0.05);
    border-color: rgba(200,241,53,0.15);
  }

  .rb-about__card-icon {
    font-size: 28px;
    line-height: 1;
  }

  .rb-about__card-title {
    font-family: 'Bebas Neue', 'Impact', sans-serif;
    font-size: 20px;
    font-weight: 400;
    color: #fff;
    letter-spacing: 0.04em;
    margin: 0;
  }

  .rb-about__card p {
    color: rgba(255,255,255,0.55);
    font-size: 14px;
    line-height: 1.7;
    margin: 0;
  }

  .rb-about__card-link {
    color: var(--rb-lime, #c8f135);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
    margin-top: auto;
    transition: opacity 0.2s;
  }

  .rb-about__card-link:hover { opacity: 0.75; }

  /* ---- Full-width photo ---- */
  .rb-about__full-photo {
    position: relative;
    z-index: 1;
    height: 420px;
    overflow: hidden;
  }

  .rb-about__full-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .rb-about__full-photo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(8,8,8,0.7) 0%, transparent 60%);
    display: flex;
    align-items: flex-end;
    padding: 32px 40px;
  }

  .rb-about__fp-label {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin: 0;
  }

  /* ---- Bottom CTA ---- */
  .rb-about__bottom-cta {
    position: relative;
    z-index: 1;
    text-align: center;
    padding-block: 80px 100px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .rb-about__bottom-title {
    font-family: 'Bebas Neue', 'Impact', sans-serif;
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 1;
  }

  .rb-about__bottom-sub {
    color: rgba(255,255,255,0.5);
    font-size: 16px;
    margin: 0;
    max-width: 440px;
  }

  .rb-about__bottom-btns {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    margin-top: 8px;
  }
</style>

{% schema %}
{
  "name": "RB — About Us",
  "tag": "section",
  "settings": [
    { "type": "text",     "id": "eyebrow",          "label": "Eyebrow",          "default": "WHO WE ARE" },
    { "type": "textarea", "id": "title",             "label": "Title",            "default": "BORN FROM\nTHE CULTURE" },
    { "type": "textarea", "id": "subtitle",          "label": "Subtitle",         "default": "Vintage streetwear, premium sneakers, and collectibles — hand-picked from the culture in Abilene, TX." },
    { "type": "header",   "label": "Story section" },
    { "type": "text",     "id": "story_heading",     "label": "Story heading",    "default": "THE STORY" },
    { "type": "textarea", "id": "story_body",        "label": "Story body",       "default": "Runitback Classics was born in Abilene, TX in 2024 with a simple idea: great vintage streetwear and rare sneakers shouldn't be hard to find. We dug through the racks so you don't have to.\n\nEvery piece we carry is hand-inspected, verified authentic, and one of a kind. Whether you're chasing a grail pair of Jordans or searching for that perfect vintage Champion hoodie, we've got you." },
    { "type": "text",     "id": "mission_heading",   "label": "Mission heading",  "default": "OUR MISSION" },
    { "type": "textarea", "id": "mission_body",      "label": "Mission body",     "default": "We believe style shouldn't break the bank. Pre-owned doesn't mean second rate — vintage pieces carry history, character, and culture that new releases simply can't replicate.\n\nBeyond the product, we're a community. Come through the shop, bring your pieces for trade, or catch us every Thursday at 6:35PM on Instagram Live for Thirsty Thursday auctions." },
    { "type": "header",   "label": "Photos" },
    { "type": "image_picker", "id": "photo_1", "label": "Photo 1 (story left)" },
    { "type": "text",         "id": "photo_1_alt", "label": "Photo 1 alt text" },
    { "type": "image_picker", "id": "photo_2", "label": "Photo 2 (story right)" },
    { "type": "text",         "id": "photo_2_alt", "label": "Photo 2 alt text" },
    { "type": "image_picker", "id": "photo_3", "label": "Photo 3 (full-width banner)" },
    { "type": "text",         "id": "photo_3_alt", "label": "Photo 3 alt text" }
  ],
  "presets": [{ "name": "RB — About Us" }]
}
{% endschema %}
