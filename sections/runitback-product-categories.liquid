<section
  class="rb-product-categories color-{{ section.settings.color_scheme }}"
  id="rb-product-categories-{{ section.id }}"
>
  <div class="rb-container rb-product-categories__inner">
    {% render 'runitback-category-rail',
      menu_handle: section.settings.menu,
      heading: section.settings.heading,
      caption: section.settings.caption,
      aria_label: section.settings.heading,
      context: 'product',
      product: product
    %}
  </div>
</section>

{% schema %}
{
  "name": "RB - Product categories",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Category menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Keep digging"
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption",
      "default": "Another lane, another piece worth running back."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-5"
    }
  ],
  "presets": [
    {
      "name": "RB - Product categories"
    }
  ]
}
{% endschema %}
