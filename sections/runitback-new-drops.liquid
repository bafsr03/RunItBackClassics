{%- assign drops_col = collections[section.settings.collection] -%}

<section class="rb-new-drops" id="rb-new-drops-{{ section.id }}">
  <div class="rb-new-drops__inner">

    <div class="rb-new-drops__head">
      <div>
        <p class="rb-new-drops__eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 class="rb-new-drops__title">{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.view_all_label != blank and drops_col != blank -%}
        <a href="{{ drops_col.url }}" class="rb-new-drops__view-all">
          {{ section.settings.view_all_label }} →
        </a>
      {%- endif -%}
    </div>

    {%- if drops_col != blank and drops_col.products_count > 0 -%}
      <div class="rb-new-drops__grid">
        {%- for product in drops_col.products limit: section.settings.max_products -%}
          {%- assign is_sold = false -%}
          {%- unless product.available -%}{%- assign is_sold = true -%}{%- endunless -%}
          {%- assign size = product.variants.first.option1 -%}
          {%- if size == 'Default Title' -%}{%- assign size = '' -%}{%- endif -%}

          <article class="rb-drop-card{% if is_sold %} rb-drop-card--sold{% endif %}">
            <a href="{{ product.url }}" class="rb-drop-card__img-link" aria-label="{{ product.title | escape }}">
              <div class="rb-drop-card__media">
                {%- if product.featured_image -%}
                  {{ product.featured_image
                    | image_url: width: 640
                    | image_tag:
                      class: 'rb-drop-card__img',
                      loading: 'lazy',
                      widths: '320, 480, 640',
                      sizes: '(min-width: 1280px) 280px, (min-width: 768px) 33vw, 50vw',
                      alt: product.title
                  }}
                {%- else -%}
                  <div class="rb-drop-card__img-placeholder"></div>
                {%- endif -%}

                {%- unless is_sold -%}
                  <div class="rb-drop-card__stamp" aria-hidden="true">JUST<br>DROPPED</div>
                {%- else -%}
                  <div class="rb-drop-card__sold-overlay" aria-hidden="true"><span>SOLD</span></div>
                {%- endunless -%}

                {%- if size != blank -%}
                  <div class="rb-drop-card__size" aria-label="Size {{ size }}">{{ size }}</div>
                {%- endif -%}
              </div>
            </a>

            <div class="rb-drop-card__info">
              <div class="rb-drop-card__info-row">
                <h3 class="rb-drop-card__title">
                  <a href="{{ product.url }}">{{ product.title }}</a>
                </h3>
                <p class="rb-drop-card__price">{{ product.price | money_without_trailing_zeros }}</p>
              </div>
              {%- if is_sold -%}
                <span class="rb-drop-card__cta rb-drop-card__cta--sold">SOLD OUT</span>
              {%- else -%}
                <a href="{{ product.url }}" class="rb-btn rb-btn--lime rb-drop-card__cta">GET IT →</a>
              {%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>

    {%- else -%}
      <div class="rb-new-drops__empty">
        <p>New drops dropping soon — follow us on Instagram for first looks.</p>
        {%- if section.settings.instagram_handle != blank -%}
          <a
            href="https://www.instagram.com/{{ section.settings.instagram_handle }}"
            target="_blank"
            rel="noopener noreferrer"
            class="rb-btn rb-btn--ghost"
          >@{{ section.settings.instagram_handle }}</a>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</section>

<style>
  /* ── RB New Drops Section ─────────────────────────────── */
  .rb-new-drops {
    background: var(--rb-black, #0a0a0a);
    color: var(--rb-white, #fff);
    padding: 72px 20px;
  }
  @media (min-width: 768px)  { .rb-new-drops { padding: 80px 40px; } }
  @media (min-width: 1280px) { .rb-new-drops { padding: 96px 64px; } }

  .rb-new-drops__inner {
    max-width: 1400px;
    margin: 0 auto;
  }

  .rb-new-drops__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 36px;
  }

  .rb-new-drops__eyebrow {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--rb-lime, #c8f135);
    margin: 0 0 10px;
  }

  .rb-new-drops__title {
    font-family: 'Bebas Neue', 'Impact', sans-serif;
    font-size: clamp(44px, 6vw, 84px);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    margin: 0;
  }

  .rb-new-drops__view-all {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--rb-lime, #c8f135);
    text-decoration: none;
    padding-bottom: 3px;
    border-bottom: 1px solid rgba(200,241,53,0.35);
    white-space: nowrap;
    flex-shrink: 0;
    transition: border-color 0.2s;
  }
  .rb-new-drops__view-all:hover { border-bottom-color: var(--rb-lime, #c8f135); }

  /* Grid */
  .rb-new-drops__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }
  @media (min-width: 640px)  { .rb-new-drops__grid { grid-template-columns: repeat(3, 1fr); gap: 14px; } }
  @media (min-width: 1024px) { .rb-new-drops__grid { grid-template-columns: repeat(4, 1fr); gap: 18px; } }

  /* Card */
  .rb-drop-card {
    display: flex;
    flex-direction: column;
    background: #111;
    overflow: hidden;
    transition: transform 0.22s ease;
  }
  .rb-drop-card:hover { transform: translateY(-4px); }
  .rb-drop-card--sold { opacity: 0.55; }

  /* Image area */
  .rb-drop-card__img-link { display: block; text-decoration: none; }
  .rb-drop-card__media {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #1a1a1a;
  }
  .rb-drop-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .rb-drop-card:hover .rb-drop-card__img { transform: scale(1.05); }
  .rb-drop-card__img-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1a1a1a 0%, #222 100%);
  }

  /* JUST DROPPED stamp */
  .rb-drop-card__stamp {
    position: absolute;
    top: 10px;
    left: 10px;
    background: var(--rb-lime, #c8f135);
    color: #0a0a0a;
    font-size: 7px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1.3;
    text-align: center;
    padding: 5px 8px;
    z-index: 2;
  }

  /* SOLD overlay */
  .rb-drop-card__sold-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }
  .rb-drop-card__sold-overlay span {
    font-family: 'Bebas Neue', 'Impact', sans-serif;
    font-size: 52px;
    letter-spacing: 0.06em;
    -webkit-text-stroke: 2px rgba(255,255,255,0.7);
    color: transparent;
  }

  /* Size pill */
  .rb-drop-card__size {
    position: absolute;
    bottom: 9px;
    right: 9px;
    background: rgba(0,0,0,0.72);
    color: #fff;
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    padding: 4px 9px;
    border: 1px solid rgba(255,255,255,0.18);
    backdrop-filter: blur(4px);
    z-index: 2;
  }

  /* Info row */
  .rb-drop-card__info {
    padding: 12px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }
  .rb-drop-card__info-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 8px;
  }
  .rb-drop-card__title {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    line-height: 1.4;
    margin: 0;
    flex: 1;
  }
  .rb-drop-card__title a { color: var(--rb-white, #fff); text-decoration: none; }
  .rb-drop-card__title a:hover { color: var(--rb-lime, #c8f135); }
  .rb-drop-card__price {
    font-size: 14px;
    font-weight: 900;
    color: var(--rb-lime, #c8f135);
    margin: 0;
    white-space: nowrap;
  }

  .rb-drop-card__cta {
    display: block;
    text-align: center;
    font-size: 10px !important;
    padding: 10px 16px !important;
    text-decoration: none;
  }
  .rb-drop-card__cta--sold {
    text-align: center;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.28);
  }

  /* Empty state */
  .rb-new-drops__empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    padding: 80px 24px;
    text-align: center;
    color: rgba(255,255,255,0.35);
    font-size: 15px;
    line-height: 1.6;
  }
</style>

{% schema %}
{
  "name": "RB — New Drops",
  "tag": "section",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Drops collection",
      "info": "Create a smart collection with condition: tag = new-drop, then select it here."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "FRESHLY POSTED · ONE OF A KIND"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "NEW DROPS"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "VIEW ALL"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max products shown",
      "min": 4,
      "max": 12,
      "step": 4,
      "default": 8
    },
    {
      "type": "text",
      "id": "instagram_handle",
      "label": "Instagram handle (empty state)",
      "default": "runitbackclassics"
    }
  ],
  "presets": [
    {
      "name": "RB — New Drops",
      "settings": {
        "eyebrow": "FRESHLY POSTED · ONE OF A KIND",
        "heading": "NEW DROPS",
        "view_all_label": "VIEW ALL",
        "max_products": 8,
        "instagram_handle": "runitbackclassics"
      }
    }
  ]
}
{% endschema %}
