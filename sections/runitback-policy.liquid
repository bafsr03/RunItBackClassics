<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap" rel="stylesheet">

<section class="rb-policy" id="rb-policy-{{ section.id }}">

  <div class="rb-policy__bg" aria-hidden="true">
    <div class="rb-policy__bg-grid"></div>
  </div>

  <div class="rb-container rb-policy__inner">

    <div class="rb-policy__header">
      <p class="rb-policy__eyebrow">{{ section.settings.eyebrow }}</p>
      <h1 class="rb-policy__title">{{ page.title }}</h1>
      {%- if page.published_at -%}
        <p class="rb-policy__date">Last updated: {{ page.published_at | date: "%B %d, %Y" }}</p>
      {%- endif -%}
    </div>

    <div class="rb-policy__body rte">
      {{ page.content }}
    </div>

    <div class="rb-policy__nav">
      <a href="/pages/faq" class="rb-policy__nav-pill">FAQ</a>
      <a href="/pages/contact" class="rb-policy__nav-pill">Contact Us</a>
      <a href="/policies/refund-policy" class="rb-policy__nav-pill">Refund Policy</a>
      <a href="/policies/shipping-policy" class="rb-policy__nav-pill">Shipping Policy</a>
      <a href="/policies/privacy-policy" class="rb-policy__nav-pill">Privacy Policy</a>
      <a href="/policies/terms-of-service" class="rb-policy__nav-pill">Terms of Service</a>
    </div>

  </div>
</section>

<style>
  .rb-policy {
    position: relative;
    background: var(--rb-dark, #101010);
    padding-block: 100px 80px;
    overflow: hidden;
    min-height: 60vh;
  }

  .rb-policy__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .rb-policy__bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(200,241,53,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(200,241,53,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .rb-policy__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 48px;
    max-width: 820px;
  }

  .rb-policy__header {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-bottom: 32px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .rb-policy__eyebrow {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--rb-lime, #c8f135);
    border: 1px solid rgba(200,241,53,0.3);
    display: inline-block;
    padding: 6px 16px;
    border-radius: 100px;
    margin: 0;
    width: fit-content;
  }

  .rb-policy__title {
    font-family: 'Bebas Neue', 'Impact', sans-serif;
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 400;
    line-height: 1;
    color: #fff;
    margin: 0;
  }

  .rb-policy__date {
    font-size: 12px;
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.06em;
    margin: 0;
  }

  /* Policy body RTE overrides */
  .rb-policy__body {
    color: rgba(255,255,255,0.65);
    font-size: 15px;
    line-height: 1.75;
  }

  .rb-policy__body h2,
  .rb-policy__body h3 {
    font-family: 'Bebas Neue', 'Impact', sans-serif;
    font-weight: 400;
    color: #fff;
    margin-top: 40px;
    margin-bottom: 12px;
    letter-spacing: 0.04em;
  }

  .rb-policy__body h2 { font-size: 28px; }
  .rb-policy__body h3 { font-size: 20px; }

  .rb-policy__body p { margin-bottom: 16px; }

  .rb-policy__body a {
    color: var(--rb-lime, #c8f135);
    text-decoration: underline;
  }

  .rb-policy__body ul,
  .rb-policy__body ol {
    padding-left: 20px;
    margin-bottom: 16px;
  }

  .rb-policy__body li { margin-bottom: 6px; }

  .rb-policy__body strong { color: rgba(255,255,255,0.85); }

  /* Related links nav */
  .rb-policy__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding-top: 32px;
    border-top: 1px solid rgba(255,255,255,0.07);
  }

  .rb-policy__nav-pill {
    display: inline-block;
    padding: 8px 18px;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 100px;
    text-decoration: none;
    transition: color 0.2s ease, border-color 0.2s ease;
    white-space: nowrap;
  }

  .rb-policy__nav-pill:hover {
    color: var(--rb-lime, #c8f135);
    border-color: rgba(200,241,53,0.35);
  }
</style>

{% schema %}
{
  "name": "RB — Policy",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "RUNITBACK CLASSICS"
    }
  ],
  "presets": [{ "name": "RB — Policy" }]
}
{% endschema %}
