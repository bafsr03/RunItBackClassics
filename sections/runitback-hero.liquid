<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap" rel="stylesheet">

<section class="rb-hero" id="rb-hero-{{ section.id }}">

  {%- comment -%} Background layers {%- endcomment -%}
  <div class="rb-hero__bg" aria-hidden="true">
    <div class="rb-hero__bg-grid"></div>
    <div class="rb-hero__bg-glow"></div>
    {%- if section.settings.show_rainbow -%}
      <div class="rb-hero__bg-rainbow"></div>
    {%- endif -%}
  </div>

  {%- comment -%} Main content {%- endcomment -%}
  <div class="rb-hero__inner">
    <div class="rb-hero__content">

      {%- if section.settings.eyebrow != blank -%}
        <p class="rb-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      <h1 class="rb-hero__title" id="rb-hero-title">
        <span class="rb-hero__title-line rb-hero__title-line--solid" data-rb-split-letters aria-label="{{ section.settings.title_line_1 }}">{{ section.settings.title_line_1 }}</span>
        <span class="rb-hero__title-line rb-hero__title-line--outline" data-rb-split-letters aria-label="{{ section.settings.title_line_2 }}">{{ section.settings.title_line_2 }}</span>
      </h1>

      {%- if section.settings.subtitle != blank -%}
        <p class="rb-hero__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}

      <div class="rb-hero__actions">
        {%- if section.settings.cta_1_label != blank -%}
          <a href="{{ section.settings.cta_1_link }}" class="rb-btn rb-btn--lime">
            {{- section.settings.cta_1_label -}}
          </a>
        {%- endif -%}
        {%- if section.settings.cta_2_label != blank -%}
          <a href="{{ section.settings.cta_2_link }}" class="rb-btn rb-btn--ghost">
            {{- section.settings.cta_2_label -}}
          </a>
        {%- endif -%}
      </div>

      {%- if section.settings.show_stats -%}
        <div class="rb-hero__stats">
          <div>
            <span class="rb-hero__stat-value">{{ section.settings.stat_1_value }}</span>
            <span class="rb-hero__stat-label">{{ section.settings.stat_1_label }}</span>
          </div>
          <div>
            <span class="rb-hero__stat-value">{{ section.settings.stat_2_value }}</span>
            <span class="rb-hero__stat-label">{{ section.settings.stat_2_label }}</span>
          </div>
          <div>
            <span class="rb-hero__stat-value">{{ section.settings.stat_3_value }}</span>
            <span class="rb-hero__stat-label">{{ section.settings.stat_3_label }}</span>
          </div>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} 3D Model Viewer {%- endcomment -%}
    {%- if section.settings.model_url != blank -%}
      <div class="rb-hero__model">
        <div class="rb-hero__model-glow" aria-hidden="true"></div>
        <model-viewer
          class="rb-hero__model-viewer"
          src="{{ section.settings.model_url }}"
          alt="{{ section.settings.model_alt | default: 'Nike Jordan 4 Retro – 3D view' }}"
          auto-rotate
          auto-rotate-delay="500"
          rotation-per-second="{{ section.settings.model_rotation_speed | default: 20 }}deg"
          camera-controls
          disable-zoom
          shadow-intensity="1.6"
          shadow-softness="0.9"
          environment-image="neutral"
          exposure="0.9"
          camera-orbit="{{ section.settings.model_camera_orbit | default: '0deg 72deg 85%' }}"
          min-camera-orbit="auto 48deg auto"
          max-camera-orbit="auto 90deg auto"
          interpolation-decay="75"
          interaction-prompt="auto"
          interaction-prompt-threshold="2000"
          loading="lazy"
          reveal="auto"
        ></model-viewer>
        <p class="rb-hero__model-hint" aria-hidden="true">DRAG TO ROTATE</p>
        {%- comment -%} Badge floats in corner of model panel on desktop {%- endcomment -%}
        <div class="rb-hero__badge-wrap rb-hero__badge-wrap--inmodel" aria-hidden="true">
          <svg class="rb-hero__badge" viewBox="0 0 200 200" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <path id="rb-badge-circle-{{ section.id }}" d="M 100,100 m -72,0 a 72,72 0 1,1 144,0 a 72,72 0 1,1 -144,0"/>
            </defs>
            <text font-size="13" font-weight="700" letter-spacing="3.5" text-anchor="start">
              <textPath href="#rb-badge-circle-{{ section.id }}" startOffset="0%">
                VINTAGE &bull; STREETWEAR &bull; RUNITBACK &bull; CLASSICS &bull;&nbsp;
              </textPath>
            </text>
            <circle cx="100" cy="100" r="8" fill="currentColor"/>
          </svg>
        </div>
      </div>
    {%- else -%}
      {%- comment -%} Fallback spinning badge when no model is set {%- endcomment -%}
      <div class="rb-hero__badge-wrap" aria-hidden="true">
        <svg class="rb-hero__badge" viewBox="0 0 200 200" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <path id="rb-badge-circle-{{ section.id }}" d="M 100,100 m -72,0 a 72,72 0 1,1 144,0 a 72,72 0 1,1 -144,0"/>
          </defs>
          <text font-size="13" font-weight="700" letter-spacing="3.5" text-anchor="start">
            <textPath href="#rb-badge-circle-{{ section.id }}" startOffset="0%">
              VINTAGE &bull; STREETWEAR &bull; RUNITBACK &bull; CLASSICS &bull;&nbsp;
            </textPath>
          </text>
          <circle cx="100" cy="100" r="8" fill="currentColor"/>
        </svg>
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} Scroll indicator {%- endcomment -%}
  <div class="rb-hero__scroll" aria-hidden="true">
    <span class="rb-hero__scroll-label">Scroll</span>
    <div class="rb-hero__scroll-line"></div>
  </div>

</section>

<style>
  /* ── Hero Title: Bebas Neue + Cipher Scramble Decode ────────── */

  /* Font */
  .rb-hero__title {
    font-family: 'Bebas Neue', 'Impact', sans-serif !important;
    font-weight: 400 !important;
    line-height: 0.9 !important;
    letter-spacing: 0 !important; /* spacing set via margin-right on .rb-letter by JS */
    overflow: visible !important;
  }

  /* Line 1 — solid white */
  .rb-hero__title-line--solid {
    display: block;
    white-space: nowrap;
    color: var(--rb-white);
  }

  /* Line 2 — outline */
  .rb-hero__title-line--outline {
    display: block;
    white-space: nowrap;
    -webkit-text-stroke: 2px var(--rb-white);
    color: transparent;
    margin-top: -0.02em;
  }

  /* Per-letter clip wrapper */
  .rb-letter {
    display: inline-block;
    vertical-align: top;
    line-height: inherit;
  }

  /* The character node — JS owns all visual state */
  .rb-letter__inner {
    display: inline-block;
    opacity: 0;
    will-change: opacity, color, filter, text-shadow;
    transition: filter 0.05s linear;
  }

  /* ── STATE: scrambling (random chars flickering in) ── */
  .rb-letter__inner.rb-scrambling {
    opacity: 1;
    filter: blur(0.5px);
    color: #444 !important;
    -webkit-text-stroke: 0 !important;
    text-shadow: none;
  }
  .rb-hero__title-line--outline .rb-letter__inner.rb-scrambling {
    color: rgba(255,255,255,0.18) !important;
    -webkit-text-stroke: 0 !important;
  }

  /* ── STATE: lock-flash on solid line → lime glow ── */
  .rb-letter__inner.rb-flash-solid {
    opacity: 1;
    color: var(--rb-lime) !important;
    -webkit-text-stroke: 0 !important;
    text-shadow:
      0 0 24px rgba(200,241,53,0.9),
      0 0 8px  rgba(200,241,53,0.6);
    filter: none;
  }

  /* ── STATE: lock-flash on outline line → chromatic split ── */
  .rb-letter__inner.rb-flash-outline {
    opacity: 1;
    color: #fff !important;
    -webkit-text-stroke: 0 !important;
    text-shadow:
      -4px 0 rgba(255, 40, 40, 0.9),
       4px 0 rgba(0, 210, 255, 0.9);
    filter: none;
  }

  /* ── STATE: locked (settled, correct letter) ── */
  .rb-letter__inner.rb-locked {
    opacity: 1;
    filter: none !important;
    text-shadow: none !important;
    transition: none;
  }

  /* Reduce-motion: skip everything, show final text */
  @media (prefers-reduced-motion: reduce) {
    .rb-letter__inner {
      opacity: 1 !important;
      color: inherit !important;
      -webkit-text-stroke: inherit !important;
      filter: none !important;
      text-shadow: none !important;
    }
  }

  /* ── 3D Model Viewer Panel ───────────────────────────────────── */

  @keyframes rb-model-float {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-12px); }
  }

  @keyframes rb-glow-pulse {
    0%, 100% { opacity: 0.7; transform: scale(1); }
    50%       { opacity: 1;   transform: scale(1.08); }
  }

  .rb-hero__model {
    position: relative;
    flex-shrink: 0;
    width: 100%;
    height: 380px;
    order: -1; /* appears above text on mobile */
    animation:
      rb-fade-in 1.1s 0.3s var(--rb-ease-out) both,
      rb-model-float 5s 1.4s ease-in-out infinite;
    transform-style: preserve-3d;
    will-change: transform;
    transition: transform 0.15s ease-out;
  }

  @media (min-width: 600px) {
    .rb-hero__model { height: 460px; }
  }

  @media (min-width: 900px) {
    .rb-hero__model { height: 520px; }
  }

  @media (min-width: 1280px) {
    .rb-hero__model {
      width: 620px;
      height: 620px;
      order: 0;
      flex-shrink: 0;
    }
  }

  /* Lime atmospheric glow behind shoe */
  .rb-hero__model-glow {
    position: absolute;
    inset: -60px;
    background: radial-gradient(ellipse at 50% 55%, rgba(200,241,53,0.14) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
    animation: rb-glow-pulse 5s 1.4s ease-in-out infinite;
  }

  /* model-viewer element */
  .rb-hero__model-viewer {
    width: 100%;
    height: 100%;
    background: transparent;
    position: relative;
    z-index: 1;
    --poster-color: transparent;
  }

  /* "DRAG TO ROTATE" micro-label */
  .rb-hero__model-hint {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 8px;
    font-weight: 800;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.22);
    pointer-events: none;
    z-index: 2;
    white-space: nowrap;
    margin: 0;
    transition: opacity 0.4s ease;
  }

  .rb-hero__model:hover .rb-hero__model-hint {
    opacity: 0;
  }

  /* Badge in model panel — bottom-right corner, smaller */
  .rb-hero__badge-wrap--inmodel {
    display: none;
    position: absolute;
    bottom: 16px;
    right: 16px;
    z-index: 3;
  }

  @media (min-width: 1280px) {
    .rb-hero__badge-wrap--inmodel {
      display: block;
      animation: rb-fade-in 1.4s 0.8s var(--rb-ease-out) both;
    }
    .rb-hero__badge-wrap--inmodel .rb-hero__badge {
      width: 110px;
      height: 110px;
    }
  }

  /* Disable float/tilt for users who prefer reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .rb-hero__model {
      animation: rb-fade-in 1.1s 0.3s var(--rb-ease-out) both !important;
    }
    .rb-hero__model-glow { animation: none !important; }
  }
</style>

{%- if section.settings.model_url != blank -%}
  <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.5.0/model-viewer.min.js"></script>
{%- endif -%}
<script src="{{ 'runitback-hero-letters.js' | asset_url }}" defer></script>

{%- if section.settings.model_url != blank -%}
<script>
(function () {
  /* Tilt-card parallax for the model panel — desktop only */
  if (window.matchMedia('(hover: none)').matches) return; /* skip touch devices */
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  var sectionEl = document.getElementById('rb-hero-{{ section.id }}');
  if (!sectionEl) return;
  var modelEl = sectionEl.querySelector('.rb-hero__model');
  if (!modelEl) return;

  var MAX_TILT = 9;   /* degrees of tilt on each axis */
  var PERSPECTIVE = 900; /* px */
  var raf = null;
  var targetX = 0, targetY = 0;
  var currentX = 0, currentY = 0;
  var isHovering = false;

  function lerp(a, b, t) { return a + (b - a) * t; }

  function tick() {
    currentX = lerp(currentX, targetX, 0.08);
    currentY = lerp(currentY, targetY, 0.08);

    var dist = Math.abs(currentX - targetX) + Math.abs(currentY - targetY);
    if (!isHovering && dist < 0.02) {
      /* settled back to zero, stop the loop */
      modelEl.style.transform = '';
      raf = null;
      return;
    }

    modelEl.style.transform =
      'perspective(' + PERSPECTIVE + 'px) ' +
      'rotateY(' + currentX + 'deg) ' +
      'rotateX(' + currentY + 'deg) ' +
      'scale3d(1.025, 1.025, 1.025)';

    raf = requestAnimationFrame(tick);
  }

  modelEl.addEventListener('mouseenter', function () {
    isHovering = true;
    modelEl.style.transition = 'none'; /* let JS drive it */
    if (!raf) raf = requestAnimationFrame(tick);
  });

  modelEl.addEventListener('mousemove', function (e) {
    var rect = modelEl.getBoundingClientRect();
    var nx = (e.clientX - rect.left) / rect.width  - 0.5; /* -0.5 → 0.5 */
    var ny = (e.clientY - rect.top)  / rect.height - 0.5;
    targetX =  nx * MAX_TILT * 2;
    targetY = -ny * MAX_TILT;
  });

  modelEl.addEventListener('mouseleave', function () {
    isHovering = false;
    targetX = 0;
    targetY = 0;
    /* transition back via CSS for a smooth spring-out */
    modelEl.style.transition = 'transform 0.7s cubic-bezier(0.23, 1, 0.32, 1)';
    if (!raf) raf = requestAnimationFrame(tick);
  });
})();
</script>
{%- endif -%}

