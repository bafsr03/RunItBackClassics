{%- liquid
  assign cur = collection.handle | default: ''
-%}

<nav class="rb-strip" id="rb-strip-{{ section.id }}" aria-label="Shop categories">
  <div class="rb-strip__inner">

    <!-- LEFT: All · Sneakers · Vintage · Streetwear -->
    <ul class="rb-strip__list rb-strip__list--left" role="list">
      <li>
        <a href="/collections/all"
           class="rb-strip__link{% if cur == 'all' %} is-active{% endif %}">
          All
        </a>
      </li>
      <li>
        <a href="/collections/sneakers"
           class="rb-strip__link{% if cur == 'sneakers' %} is-active{% endif %}">
          Sneakers
        </a>
      </li>
      <li>
        <a href="/collections/vintage"
           class="rb-strip__link{% if cur == 'vintage' %} is-active{% endif %}">
          Vintage
        </a>
      </li>
      <li>
        <a href="/collections/streetwear"
           class="rb-strip__link{% if cur == 'streetwear' %} is-active{% endif %}">
          Streetwear
        </a>
      </li>
    </ul>

    <!-- CENTER — spacer aligned with logo above -->
    <div class="rb-strip__spacer" aria-hidden="true"></div>

    <!-- RIGHT: Trading Cards · Bottoms · Accessories · Clearance -->
    <ul class="rb-strip__list rb-strip__list--right" role="list">
      <li>
        <a href="/collections/trading-cards"
           class="rb-strip__link{% if cur == 'trading-cards' %} is-active{% endif %}">
          Trading Cards
        </a>
      </li>
      <li>
        <a href="/collections/bottoms"
           class="rb-strip__link{% if cur == 'bottoms' %} is-active{% endif %}">
          Bottoms
        </a>
      </li>
      <li>
        <a href="/collections/accessories"
           class="rb-strip__link{% if cur == 'accessories' %} is-active{% endif %}">
          Accessories
        </a>
      </li>
      <li>
        <a href="/collections/clearance"
           class="rb-strip__link rb-strip__link--sale{% if cur == 'clearance' %} is-active{% endif %}">
          Clearance
        </a>
      </li>
    </ul>

  </div>
</nav>

{% stylesheet %}
/* ================================================================
   RB SHOP STRIP — mirrors navbar: left list | spacer | right list
   ================================================================ */

.rb-strip {
  background: #0d0d0d;
  border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  position: relative;
  z-index: 9997;
  width: 100%;
}

.rb-strip__inner {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  height: 38px;
  max-width: var(--page-width, 1440px);
  margin: 0 auto;
  padding: 0 max(24px, env(safe-area-inset-left));
}

/* Center spacer — matches the fixed navbar logo column */
.rb-strip__spacer {
  width: 160px;
  height: 1px;
}

/* ── Lists ── */
.rb-strip__list {
  display: flex;
  align-items: center;
  list-style: none;
  margin: 0;
  padding: 0;
  height: 100%;
}

.rb-strip__list--left  { justify-content: flex-end; }
.rb-strip__list--right { justify-content: flex-start; }

/* ── Links ── */
.rb-strip__link {
  display: flex;
  align-items: center;
  height: 100%;
  padding: 0 16px;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.42);
  text-decoration: none;
  white-space: nowrap;
  position: relative;
  transition: color 0.2s ease;
}

.rb-strip__link::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 16px;
  right: 16px;
  height: 2px;
  background: #c8f135;
  transform: scaleX(0);
  transform-origin: center;
  transition: transform 0.22s ease;
}

.rb-strip__link:hover,
.rb-strip__link.is-active {
  color: #fff;
}

.rb-strip__link:hover::after,
.rb-strip__link.is-active::after {
  transform: scaleX(1);
}

/* Clearance — red accent */
.rb-strip__link--sale {
  color: rgba(255, 70, 70, 0.55);
}

.rb-strip__link--sale:hover,
.rb-strip__link--sale.is-active {
  color: #ff4646;
}

.rb-strip__link--sale::after {
  background: #ff4646;
}

/* Mobile: hide strip on small screens (handled by hamburger menu) */
@media (max-width: 989px) {
  .rb-strip { display: none; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "RB — Shop Strip",
  "tag": "section",
  "settings": [],
  "presets": [{ "name": "RB — Shop Strip" }]
}
{% endschema %}
