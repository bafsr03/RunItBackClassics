{%- liquid
  assign social_block = section.blocks | where: 'type', 'social' | first
  assign nav_columns  = section.blocks | where: 'type', 'nav_column'
-%}

<footer class="rb-foot" id="rb-footer-{{ section.id }}">

  {%- comment -%} ── MAIN FOOTER ── {%- endcomment -%}
  <div class="rb-foot__main">
    <div class="rb-container rb-foot__main-inner">

      <div class="rb-foot__main-left">
        <div class="rb-foot__brand">
          {%- if settings.logo != blank -%}
            <a href="/" class="rb-foot__logo-link">
              {{- settings.logo | image_url: height: 140 | image_tag:
                alt: shop.name,
                class: 'rb-foot__logo',
                loading: 'lazy',
                style: 'filter: invert(1); mix-blend-mode: screen; max-height:140px; width:auto;'
              -}}
          </a>
        {%- else -%}
          <a href="/" class="rb-foot__wordmark">{{ shop.name | upcase }}</a>
        {%- endif -%}
        {%- if section.settings.tagline != blank -%}
          <p class="rb-foot__tagline">{{ section.settings.tagline }}</p>
        {%- endif -%}
      </div>

      {%- if social_block != blank -%}
        <div class="rb-foot__social" {{ social_block.shopify_attributes }}>
          {%- if social_block.settings.instagram != blank -%}
            <a href="{{ social_block.settings.instagram }}" class="rb-foot__social-link" target="_blank" rel="noopener" aria-label="Instagram">
              <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
          {%- endif -%}
          {%- if social_block.settings.facebook != blank -%}
            <a href="{{ social_block.settings.facebook }}" class="rb-foot__social-link" target="_blank" rel="noopener" aria-label="Facebook">
              <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          {%- endif -%}

          {%- if social_block.settings.tiktok != blank -%}
            <a href="{{ social_block.settings.tiktok }}" class="rb-foot__social-link" target="_blank" rel="noopener" aria-label="TikTok">
              <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
            </a>
          {%- endif -%}

        </div>
      {%- endif -%}

      </div>

      {%- if nav_columns.size > 0 -%}
        <div class="rb-foot__nav-wrap">
          <div class="rb-foot__nav-grid" style="--rb-foot-cols: {{ nav_columns.size }};">
        {%- for block in nav_columns -%}
          <div class="rb-foot__nav-col" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <p class="rb-foot__nav-title">{{ block.settings.title | upcase }}</p>
            {%- endif -%}
            {%- if block.settings.menu != blank -%}
              {%- assign nav_menu = linklists[block.settings.menu] -%}
              {%- if nav_menu != blank -%}
                <ul class="rb-foot__nav-list">
                  {%- for link in nav_menu.links -%}
                    <li><a href="{{ link.url }}" class="rb-foot__nav-link">{{ link.title }}</a></li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            {%- else -%}
              {%- comment -%} Fallback: manual links 1–6 {%- endcomment -%}
              <ul class="rb-foot__nav-list">
                {%- for i in (1..6) -%}
                  {%- assign lbl_key = 'link_' | append: i | append: '_label' -%}
                  {%- assign url_key = 'link_' | append: i | append: '_url' -%}
                  {%- assign lbl = block.settings[lbl_key] -%}
                  {%- assign url = block.settings[url_key] -%}
                  {%- if lbl != blank -%}
                    <li><a href="{{ url | default: '#' }}" class="rb-foot__nav-link">{{ lbl }}</a></li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  </div>
</div>

  {%- comment -%} ── SEO TAGS ROW ── {%- endcomment -%}
  {%- if section.settings.seo_links != blank -%}
    {%- assign seo_items = section.settings.seo_links | split: '|' -%}
    <div class="rb-foot__seo">
      <div class="rb-container rb-foot__seo-inner">
        {%- for item in seo_items -%}
          {%- assign parts = item | split: '::' -%}
          {%- assign seo_label = parts[0] | strip -%}
          {%- assign seo_url   = parts[1] | strip | default: '/collections/all' -%}
          <a href="{{ seo_url }}" class="rb-foot__seo-link">{{ seo_label }}</a>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ── BOTTOM BAR ── {%- endcomment -%}
  <div class="rb-foot__bottom">
    <div class="rb-container rb-foot__bottom-inner">
      <div class="rb-foot__bottom-left">
        <p class="rb-foot__copy">
          &copy; {{ 'now' | date: '%Y' }}
          {{ section.settings.copyright_text | default: shop.name }}
        </p>
        <div class="rb-foot__bottom-links">
          {%- for link in linklists['footer'].links -%}
            <a href="{{ link.url }}" class="rb-foot__bottom-link">{{ link.title }}</a>
          {%- endfor -%}
        </div>
      </div>
      <div class="rb-foot__powered">
        <span>Powered by</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="120" height="32" viewBox="0 0 149 42" fill="none"><path d="M38.228 15.6652C38.7285 15.6652 38.9509 16.0502 38.7285 16.5452L29.4412 36.1802C29.2188 36.6752 28.6071 37.0602 28.1066 37.0602H12.8688C12.8132 37.0602 12.702 37.1152 12.6464 37.1152L1.0234 41.7902C0.300445 42.0652 -0.200065 41.6252 0.0779958 40.9652L16.8173 5.49021C16.9841 5.16021 17.3178 4.83021 17.7071 4.66521L28.8295 0.210209C29.5525 -0.064794 30.1086 0.375207 29.7749 1.03521L23.1015 15.1702C22.9902 15.4452 23.0458 15.6652 23.3239 15.6652H38.228ZM26.1601 20.1202C26.327 19.8452 26.2157 19.6802 25.9377 19.6802H21.4331C21.155 19.6802 20.877 19.8452 20.7657 20.1202L14.8708 32.6052C14.7596 32.8802 14.8708 33.0452 15.0933 33.0452H19.6535C19.8759 33.0452 20.154 32.8802 20.2652 32.6052L26.1601 20.1202Z" fill="white"></path><path d="M67.4094 15.6652C67.9099 15.6652 68.1323 16.0502 67.9099 16.5452L58.6227 36.1802C58.4002 36.6752 57.7885 37.0602 57.288 37.0602H32.04C31.5395 37.0602 31.317 36.6752 31.5395 36.1802L40.8267 16.5452C41.0492 16.0502 41.6609 15.6652 42.1614 15.6652H67.4094ZM55.3971 20.1202C55.5084 19.8452 55.3971 19.6802 55.1191 19.6802H50.6145C50.392 19.6802 50.0584 19.8452 49.9471 20.1202L44.0522 32.6052C43.941 32.8802 44.0522 33.0452 44.3303 33.0452H48.8349C49.0573 33.0452 49.391 32.8802 49.5022 32.6052L55.3971 20.1202Z" fill="white"></path><path d="M96.6021 15.6652C97.1026 15.6652 97.325 16.0502 97.1026 16.5452L87.8153 36.1802C87.5929 36.6752 86.9812 37.0602 86.4807 37.0602H61.2327C60.7322 37.0602 60.5097 36.6752 60.7322 36.1802L70.0194 16.5452C70.2419 16.0502 70.8536 15.6652 71.3541 15.6652H80.3633C80.8638 15.6652 81.0863 16.0502 80.8638 16.5452L73.2449 32.6052C73.1337 32.8802 73.2449 33.0452 73.523 33.0452H78.0276C78.25 33.0452 78.5837 32.8802 78.6949 32.6052L86.2582 16.5452C86.4807 16.0502 87.0924 15.6652 87.5929 15.6652H96.6021Z" fill="white"></path><path d="M116.396 0.210209C117.175 -0.064794 117.675 0.375207 117.342 1.03521L100.769 36.1802C1