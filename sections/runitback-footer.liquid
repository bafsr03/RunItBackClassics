      </div>
    </div>
  </div>

</footer>

{% stylesheet %}
/* ================================================================
   RB FOOTER
   ================================================================ */

.rb-foot {
  background: #080808;
  color: #ffffff;
  border-top: 1px solid #1e1e1e;
}

/* Main layout */
.rb-foot__main { padding: 64px 0 56px; }

.rb-foot__main-inner {
  display: flex;
  flex-direction: column;
  gap: 48px;
}

@media (min-width: 1024px) {
  .rb-foot__main-inner {
    flex-direction: row;
    justify-content: space-between;
    gap: 80px;
  }
}

.rb-foot__main-left {
  display: flex;
  flex-direction: column;
  gap: 32px;
  max-width: 320px;
}

.rb-foot__brand { max-width: 100%; }

.rb-foot__logo-link { display: inline-block; margin-bottom: 16px; }
.rb-foot__logo { display: block; }

.rb-foot__wordmark {
  display: inline-block;
  font-size: 20px;
  font-weight: 900;
  letter-spacing: 0.08em;
  color: #ffffff;
  text-decoration: none;
  margin-bottom: 16px;
}

.rb-foot__tagline {
  font-size: 13px;
  color: #888888;
  letter-spacing: 0.06em;
  margin: 0;
  line-height: 1.6;
}

/* Social icons */
.rb-foot__social {
  display: flex;
  gap: 16px;
  align-items: center;
  flex-wrap: wrap;
}

.rb-foot__social-link {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border: 1px solid #2a2a2a;
  color: #888888;
  text-decoration: none;
  transition: color 0.22s ease, border-color 0.22s ease, background 0.22s ease;
}
.rb-foot__social-link:hover {
  color: #080808;
  background: #c8f135;
  border-color: #c8f135;
}

/* Nav columns */
.rb-foot__nav-wrap { 
  padding: 0; 
  flex-grow: 1;
  max-width: 800px;
}

.rb-foot__nav-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 40px 24px;
}

@media (min-width: 640px) {
  .rb-foot__nav-grid { grid-template-columns: repeat(3, 1fr); }
}

@media (min-width: 1024px) {
  .rb-foot__nav-grid {
    grid-template-columns: repeat(var(--rb-foot-cols, 4), 1fr);
    gap: 0 40px;
  }
}

.rb-foot__nav-title {
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: #ffffff;
  margin: 0 0 20px;
}

.rb-foot__nav-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.rb-foot__nav-link {
  font-size: 13px;
  color: #666666;
  text-decoration: none;
  transition: color 0.2s ease;
  line-height: 1.4;
}
.rb-foot__nav-link:hover { color: #c8f135; }

/* SEO tag row */
.rb-foot__seo {
  border-top: 1px solid #1e1e1e;
  padding: 18px 0;
  background: #080808;
}

.rb-foot__seo-inner {
  display: flex;
  flex-wrap: wrap;
  gap: 8px 0;
}

.rb-foot__seo-link {
  font-size: 11px;
  color: #444444;
  text-decoration: none;
  padding: 0 16px;
  border-right: 1px solid #2a2a2a;
  transition: color 0.2s ease;
  white-space: nowrap;
  line-height: 1.4;
}
.rb-foot__seo-link:first-child { padding-left: 0; }
.rb-foot__seo-link:last-child { border-right: none; }
.rb-foot__seo-link:hover { color: #888888; }

/* Bottom bar */
.rb-foot__bottom {
  border-top: 1px solid #1e1e1e;
  padding: 20px 0;
  background: #080808;
}

.rb-foot__bottom-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  flex-wrap: wrap;
}

.rb-foot__copy {
  font-size: 11px;
  color: #444444;
  margin: 0;
  letter-spacing: 0.06em;
}

.rb-foot__bottom-links {
  display: flex;
  flex-wrap: wrap;
  gap: 6px 0;
}

.rb-foot__bottom-link {
  font-size: 11px;
  color: #444444;
  text-decoration: none;
  padding: 0 14px;
  border-right: 1px solid #2a2a2a;
  transition: color 0.2s ease;
  white-space: nowrap;
}
.rb-foot__bottom-link:last-child { border-right: none; }
.rb-foot__bottom-link:hover { color: #888888; }

.rb-foot__bottom-left {
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}

.rb-foot__powered {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 10px;
  color: #666666;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.rb-foot__powered svg {
  width: 72px;
  height: auto;
  opacity: 0.9;
}

@media (max-width: 640px) {
  .rb-foot__main { padding: 48px 0; }
  .rb-foot__main-inner { gap: 40px; }
  .rb-foot__bottom-inner { flex-direction: column; align-items: flex-start; gap: 20px; }
  .rb-foot__bottom-left { flex-direction: column; align-items: flex-start; gap: 8px; }
  .rb-foot__powered { width: 100%; justify-content: flex-start; margin-top: 8px; }
}
{% endstylesheet %}

{% schema %}
